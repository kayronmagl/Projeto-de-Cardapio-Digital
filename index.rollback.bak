<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="Img/Logo_do_T.lanches.png">
  <title>Tobia's Lanches</title>
  <link rel="stylesheet" href="styles.css">
</head>

<body>
  <a class="skip-link" href="#areaProdutos">Pular para o cardápio</a>
  <div class="fundo-animado" aria-hidden="true"></div>

  <header class="topo layout-shell" id="topo">
    <div class="caixa-logo">
      <img src="Img/Logo_do_T.lanches.png" alt="Logo do Tobia's Lanches" class="logo-site">
      <div class="marca-topo">
        <h1 class="titulo-site">Tobia's Lanches</h1>
        <p class="subtitulo-topo">Quiosque 03 | Iracema-CE</p>
      </div>
    </div>
    <button id="botaoCarrinho" type="button" aria-controls="caixaCarrinho" aria-expanded="false">
      Carrinho (<span id="quantidadeCarrinho">0</span>)
    </button>
  </header>

  <section class="topo-blocos layout-shell" aria-label="Resumo inicial">
    <section class="hero" aria-label="Destaques do atendimento">
      <p class="hero-kicker">Cardápio digital do Tobia's Lanches</p>
      <h2 class="hero-title">Peça rápido e sem complicação.</h2>
      <p class="hero-subtitle">Delivery, retirada e pedido no local com confirmação no WhatsApp.</p>
      <div class="hero-metas" aria-label="Informações rápidas">
        <span class="hero-meta">Tempo médio: 20 a 40 min</span>
        <span class="hero-meta">Pagamento: PIX, cartão e dinheiro</span>
      </div>
      <ul class="hero-chips">
        <li class="chip">Delivery</li>
        <li class="chip">Retirada</li>
        <li class="chip">No local</li>
      </ul>
    </section>

    <section class="faixa-operacao" aria-live="polite">
      <div class="painel-horario">
        <div class="painel-horario-topo">
          <div class="painel-horario-head">
            <p class="titulo-horario">Horários de funcionamento</p>
            <p class="horario-ajuda">Atualizado automaticamente</p>
          </div>
          <p id="statusLoja" class="status-loja" aria-live="polite" role="status"></p>
        </div>
        <div class="painel-horario-grade">
          <div class="horario-bloco">
            <p class="rotulo-horario">Próximo horário</p>
            <p id="detalheHorario" class="detalhe-horario"></p>
          </div>
          <div class="horario-bloco">
            <p class="rotulo-horario">Agenda semanal</p>
            <ul class="agenda-horario" aria-label="Agenda semanal">
              <li class="agenda-mensagem">Carregando horários...</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </section>

  <nav id="menuCategorias" class="menu-categorias layout-shell" aria-label="Categorias do cardápio"></nav>
  <p id="statusCategoria" class="sr-only" aria-live="polite"></p>

  <main id="areaProdutos" class="grade-produtos layout-shell" aria-live="polite"></main>

  <footer class="rodape-utilitarios layout-shell" aria-label="Créditos do site e acessos internos">
    <p class="rodape-nota">Criado e desenvolvido por <a class="link-assinatura"
        href="https://www.instagram.com/kayronmagl/" target="_blank" rel="noopener noreferrer"
        aria-label="Instagram de Kayron Magalhães">Kayron Magalhães <span class="icone-instagram-assinatura"
          aria-hidden="true"><svg viewBox="0 0 24 24" focusable="false">
            <rect x="3.5" y="3.5" width="17" height="17" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.4" cy="6.6" r="1.1" class="ponto-instagram"></circle>
          </svg></span></a></p>
    <button id="botaoAbrirAdmin" type="button" class="link-admin" aria-controls="painelAdmin"
      aria-expanded="false">Abrir área administrativa</button>
  </footer>

  <section id="caixaCarrinho" class="fundo-escuro" tabindex="-1" hidden inert>
    <div class="caixa-centro caixa-carrinho" role="dialog" aria-modal="true" aria-labelledby="tituloCarrinho">
      <h2 class="titulo-caixa" id="tituloCarrinho">Carrinho e Checkout</h2>
      <div class="carrinho-conteudo">
        <p id="carrinhoSubtitulo" class="carrinho-subtitulo">Seu carrinho está vazio.</p>
        <div id="resumoTopoCarrinho" class="resumo-topo-carrinho" aria-live="polite">
          <span id="resumoTopoItens">Itens: 0 item</span>
          <strong id="resumoTopoSubtotal">Subtotal: R$ 0,00</strong>
        </div>

        <div class="cart-card">
          <p class="cart-section-title">Itens do pedido</p>
          <section class="painel-carrinho" aria-label="Itens do carrinho">
            <ul id="listaCarrinho"></ul>
          </section>
          <p class="cart-section-title">Resumo do pedido</p>
          <section class="totais-carrinho" aria-label="Resumo financeiro do pedido">
            <p id="resumoPedido" class="resumo-pedido"></p>
            <p id="valorTotal"></p>
          </section>
        </div>

        <form id="formCliente" novalidate>
          <fieldset class="bloco-form">
            <legend>1. Tipo de atendimento</legend>
            <div class="segmented" role="radiogroup" aria-label="Tipo de atendimento">
              <label class="segmented-item">
                <input type="radio" name="tipoAtendimento" value="delivery" checked>
                <span>Delivery</span>
              </label>
              <label class="segmented-item">
                <input type="radio" name="tipoAtendimento" value="no_local">
                <span>No Local</span>
              </label>
            </div>
          </fieldset>

          <fieldset class="bloco-form" id="blocoDelivery">
            <legend>2. Pedido via site</legend>
            <label for="tipoEntrega">Pedido para:</label>
            <select id="tipoEntrega" data-erro-id="erroTipoEntrega" aria-describedby="ajudaTipoEntrega erroTipoEntrega"
              required>
              <option value="">Selecione</option>
              <option value="entrega">Entrega</option>
              <option value="retirada">Retirada no local</option>
            </select>
            <p id="ajudaTipoEntrega" class="ajuda-texto">Escolha entrega para receber no endereço ou retirada para buscar
              no quiosque.</p>
            <p id="erroTipoEntrega" class="erro erro-campo oculto"></p>

            <p class="aviso tempo-espera">Tempo aproximado: 20 a 40 minutos.</p>
            <div id="camposEntrega" class="painel-condicional oculto">
              <label for="bairroEntrega">Localidade de entrega (Iracema - CE):</label>
              <select id="bairroEntrega" data-erro-id="erroBairroEntrega" aria-describedby="erroBairroEntrega">
                <option value="">Selecione a localidade</option>
              </select>
              <p id="erroBairroEntrega" class="erro erro-campo oculto"></p>

              <label for="enderecoEntrega">Endereço para entrega:</label>
              <input type="text" id="enderecoEntrega" data-erro-id="erroEnderecoEntrega"
                aria-describedby="erroEnderecoEntrega" placeholder="Rua, número e complemento">
              <p id="erroEnderecoEntrega" class="erro erro-campo oculto"></p>

              <label for="referencia">Ponto de referência:</label>
              <input type="text" id="referencia" placeholder="Ex.: perto da praça">

              <p id="taxaEntregaInfo" class="aviso taxa"></p>
              <p id="bloqueioEntregaInfo" class="erro oculto" role="alert"></p>
            </div>

            <div id="enderecoRetirada" class="painel-condicional oculto">
              <p class="aviso aviso-retirada">
                <strong>Retirada no local:</strong><br>
                Carregando endereço...
              </p>
            </div>
          </fieldset>

          <fieldset class="bloco-form oculto" id="blocoNoLocal">
            <legend>2. Pedido no local</legend>
            <p class="aviso tempo-espera">Tempo aproximado: 20 a 40 minutos.</p>
            <label for="numeroMesa">Número da mesa:</label>
            <input type="number" id="numeroMesa" min="1" step="1" data-erro-id="erroNumeroMesa"
              aria-describedby="erroNumeroMesa" placeholder="Ex.: 3">
            <p id="erroNumeroMesa" class="erro erro-campo oculto"></p>
          </fieldset>

          <fieldset class="bloco-form">
            <legend>3. Dados do cliente</legend>
            <label for="nome">Nome completo:</label>
            <input type="text" id="nome" autocomplete="name" data-erro-id="erroNome" aria-describedby="ajudaNome erroNome"
              required>
            <p id="ajudaNome" class="ajuda-texto">Informe o nome usado para identificação do pedido.</p>
            <p id="erroNome" class="erro erro-campo oculto"></p>

            <div id="blocoTelefone">
              <label for="telefone">Telefone ou WhatsApp:</label>
              <input type="tel" id="telefone" inputmode="tel" autocomplete="tel" data-erro-id="erroTelefone"
                aria-describedby="ajudaTelefone erroTelefone" placeholder="(88) 98888-7777" required>
              <p id="ajudaTelefone" class="ajuda-texto">Use DDD + número.</p>
              <p id="erroTelefone" class="erro erro-campo oculto"></p>
            </div>
          </fieldset>

          <fieldset class="bloco-form">
            <legend>4. Pagamento</legend>
            <label for="pagamento">Forma de pagamento:</label>
            <select id="pagamento" data-erro-id="erroPagamento" aria-describedby="erroPagamento" required>
              <option value="">Selecione</option>
              <option value="Pix">Pix</option>
              <option value="Dinheiro">Dinheiro</option>
              <option value="Cartão">Cartão</option>
            </select>
            <p id="erroPagamento" class="erro erro-campo oculto"></p>

            <div id="pixInfo" class="painel-condicional oculto">
              <div class="pix-card">
                <p class="pix-titulo">Dados do PIX</p>
                <p class="pix-linha"><strong>Chave:</strong> <span id="chavePixTexto" class="pix-valor">-</span></p>
                <p class="pix-linha"><strong>Titular:</strong> <span id="pixTitularTexto" class="pix-valor">-</span></p>
                <p class="pix-linha"><strong>Banco:</strong> <span id="pixBancoTexto" class="pix-valor">-</span></p>
              </div>
              <button type="button" id="botaoCopiarPix" class="botao botao-secundario">Copiar chave PIX</button>
              <p id="mensagemCopiaPix" class="sucesso oculto" role="status">Chave PIX copiada.</p>
              <p id="mensagemErroCopiaPix" class="erro oculto" role="alert"></p>
            </div>

            <div id="trocoInfo" class="painel-condicional oculto">
              <label class="checkbox-linha">
                <input type="checkbox" id="precisaTroco">
                Precisa de troco?
              </label>

              <div id="trocoParaBox" class="oculto">
                <label for="trocoPara">Troco para quanto?</label>
                <input type="number" id="trocoPara" min="0" step="0.01" data-erro-id="erroTrocoPara"
                  aria-describedby="erroTrocoPara" placeholder="Ex.: 50">
                <p id="erroTrocoPara" class="erro erro-campo oculto"></p>
              </div>
            </div>
          </fieldset>

          <fieldset class="bloco-form">
            <legend>5. Observações</legend>
            <label for="observacoes">Detalhes do pedido:</label>
            <textarea id="observacoes" placeholder="Ex.: sem cebola, sem verdura, etc."></textarea>
          </fieldset>

          <fieldset class="bloco-form">
            <legend>6. Consentimento</legend>
            <label class="checkbox-linha">
              <input type="checkbox" id="aceiteLgpd" data-erro-id="erroAceiteLgpd" aria-describedby="erroAceiteLgpd">
              Autorizo o uso dos meus dados para contato e processamento deste pedido.
            </label>
            <p id="erroAceiteLgpd" class="erro erro-campo oculto"></p>
          </fieldset>

          <button type="submit" class="sr-only" tabindex="-1">Enviar pedido</button>
          <p id="mensagemErro" class="erro oculto" role="alert" tabindex="-1"></p>
        </form>
      </div>

      <div class="botoes-carrinho acoes-checkout">
        <button id="botaoFinalizar" class="botao botao-principal" type="button">Finalizar Pedido</button>
        <button id="botaoFechar" class="botao botao-secundario" type="button">Fechar</button>
      </div>
    </div>
  </section>

  <section id="modalConfirmacao" class="fundo-escuro" tabindex="-1" hidden inert>
    <div class="caixa-centro caixa-confirmacao" role="dialog" aria-modal="true" aria-labelledby="tituloConfirmacao">
      <button id="botaoFecharConfirmacaoTopo" class="botao-fechar-modal" type="button"
        aria-label="Fechar confirmação">&times;</button>
      <h2 class="titulo-caixa" id="tituloConfirmacao">Confirmar pedido</h2>
      <p class="aviso">Confira os dados abaixo antes de enviar para o WhatsApp.</p>
      <div id="resumoConfirmacao" class="resumo-confirmacao"></div>
      <div class="botoes-carrinho">
        <button id="botaoConfirmarEnvio" class="botao botao-principal" type="button">Confirmar e Enviar</button>
        <button id="botaoCancelarConfirmacao" class="botao botao-secundario" type="button">Voltar</button>
      </div>
    </div>
  </section>

  <section id="painelAdmin" class="fundo-escuro" tabindex="-1" hidden inert>
    <div class="caixa-centro caixa-admin" role="dialog" aria-modal="true" aria-labelledby="tituloAdmin">
      <button id="botaoFecharAdmin" class="botao-fechar-modal" type="button"
        aria-label="Fechar painel administrativo">×</button>
      <header class="admin-topo">
        <p class="admin-topo-kicker">Área administrativa</p>
        <h2 class="titulo-caixa" id="tituloAdmin">Painel do Cardápio</h2>
        <p class="admin-topo-descricao">Gerencie itens, adicionais e regras de combo sem editar código.</p>
        <ul class="admin-topo-chips">
          <li class="admin-topo-chip">Produtos</li>
          <li class="admin-topo-chip">Adicionais</li>
          <li class="admin-topo-chip">Combos</li>
        </ul>
      </header>

      <section id="adminLoginBloco" class="bloco-form">
        <h3 class="admin-subtitulo">Acesso</h3>
        <p class="admin-descricao admin-descricao-login">Use seu e-mail e senha para liberar edição de produtos,
          adicionais e combos.</p>
        <form id="adminLoginForm" novalidate>
          <label for="adminEmail">E-mail</label>
          <input type="email" id="adminEmail" autocomplete="email" placeholder="email@dominio.com">
          <label for="adminSenha">Senha</label>
          <input type="password" id="adminSenha" autocomplete="current-password" placeholder="Digite sua senha">
          <button type="submit" id="botaoEntrarAdmin" class="botao botao-principal">Entrar</button>
        </form>
      </section>
      <p id="adminErro" class="erro oculto admin-erro" role="alert"></p>

      <div id="adminConteudo" class="oculto">
        <section class="admin-resumo" aria-label="Resumo do cardápio">
          <article class="admin-metrica">
            <span class="admin-metrica-rotulo">Produtos</span>
            <strong id="adminTotalProdutos">0</strong>
          </article>
          <article class="admin-metrica">
            <span class="admin-metrica-rotulo">Disponíveis</span>
            <strong id="adminTotalDisponiveis">0</strong>
          </article>
          <article class="admin-metrica">
            <span class="admin-metrica-rotulo">Combos possíveis</span>
            <strong id="adminTotalCombos">0</strong>
          </article>
        </section>

        <nav class="admin-tabs" role="tablist" aria-label="Seções do painel">
          <button type="button" id="adminTabProdutos" class="admin-tab ativo" data-admin-tab="produtos" role="tab"
            aria-controls="painelAdminProdutos" aria-selected="true">Produtos</button>
          <button type="button" id="adminTabAdicionais" class="admin-tab" data-admin-tab="adicionais" role="tab"
            aria-controls="painelAdminAdicionais" aria-selected="false">Adicionais</button>
          <button type="button" id="adminTabCombos" class="admin-tab" data-admin-tab="combos" role="tab"
            aria-controls="painelAdminCombos" aria-selected="false">Combos</button>
        </nav>

        <section id="painelAdminProdutos" class="admin-painel ativo" data-admin-painel="produtos" role="tabpanel"
          aria-labelledby="adminTabProdutos">
          <div class="admin-produtos-grid">
            <section class="bloco-form admin-bloco admin-bloco-editor">
              <div class="admin-headline admin-headline-editor">
                <p class="admin-kicker">Editor de produto</p>
                <h3 class="admin-subtitulo">Cadastro de Produto</h3>
                <p class="admin-descricao">Preencha os campos essenciais, revise os adicionais e salve quando o item
                  estiver pronto para aparecer no cardápio.</p>
              </div>
              <div class="admin-guia">
                <p class="admin-guia-titulo">Fluxo recomendado</p>
                <ol class="admin-guia-lista">
                  <li>Cadastre ou edite o item.</li>
                  <li>Confirme a disponibilidade.</li>
                  <li>Aplique adicionais (quando houver).</li>
                </ol>
              </div>
              <input type="hidden" id="adminProdutoId">

              <div class="admin-form-grid">
                <div class="admin-campo admin-campo-completo">
                  <label for="adminNomeProduto">Nome</label>
                  <input type="text" id="adminNomeProduto" maxlength="80">
                  <p class="admin-ajuda">Use o mesmo nome que o cliente verá no cardápio.</p>
                </div>

                <div class="admin-campo admin-campo-completo">
                  <label for="adminDescricaoProduto">Descrição</label>
                  <textarea id="adminDescricaoProduto" maxlength="180"
                    placeholder="Descrição curta do item"></textarea>
                  <p class="admin-ajuda">Explique o sabor, recheio ou diferencial em uma frase curta.</p>
                </div>

                <div class="admin-campo admin-campo-preco">
                  <label for="adminPrecoProduto">Preço</label>
                  <div class="admin-input-prefix">
                    <span>R$</span>
                    <input type="number" id="adminPrecoProduto" min="0" step="0.01">
                  </div>
                  <p class="admin-ajuda">Use ponto ou vírgula para os centavos.</p>
                </div>

                <div class="admin-campo">
                  <label for="adminCategoriaProduto">Categoria</label>
                  <select id="adminCategoriaProduto">
                    <option value="">Carregando categorias...</option>
                  </select>
                  <p class="admin-ajuda">Define em qual grupo esse item aparece no cardápio.</p>
                </div>
              </div>

              <div class="admin-status-box">
                <label class="checkbox-linha">
                  <input type="checkbox" id="adminDisponivelProduto" checked>
                  Produto disponível
                </label>
                <p class="admin-ajuda">Se desmarcar, o item continua salvo, mas deixa de aparecer para o cliente.</p>
              </div>

              <section id="adminAdicionaisBox" class="admin-editor-box">
                <div class="admin-headline admin-headline-secundario">
                  <h4 class="admin-secao-titulo">Adicionais permitidos</h4>
                  <p class="admin-descricao">Marque quais adicionais combinam com este item.</p>
                </div>
                <div id="adminAdicionaisChecklist" class="add-on-list"></div>
              </section>

              <div class="botoes-carrinho admin-acoes-editor">
                <button type="button" id="botaoSalvarProduto" class="botao botao-principal">Salvar Produto</button>
                <button type="button" id="botaoLimparProduto" class="botao botao-secundario">Limpar</button>
              </div>
              <p id="adminProdutoMsg" class="sucesso oculto" role="status"></p>
            </section>

            <section class="bloco-form admin-bloco admin-bloco-lista">
              <div class="admin-headline">
                <h3 class="admin-subtitulo">Itens Cadastrados</h3>
                <p class="admin-descricao">Edite, pause ou exclua os itens existentes.</p>
              </div>

              <section class="admin-filtros-area" aria-label="Filtros da lista de produtos">
                <h4 class="admin-secao-titulo">Filtros</h4>
                <div class="admin-filtros" role="group" aria-label="Filtros de produtos">
                  <div class="admin-campo">
                    <label for="adminBuscaProduto">Buscar por nome</label>
                    <input type="search" id="adminBuscaProduto" placeholder="Ex.: Frango Catupiry">
                  </div>
                  <div class="admin-campo">
                    <label for="adminFiltroCategoria">Categoria</label>
                    <select id="adminFiltroCategoria">
                      <option value="">Todas</option>
                    </select>
                  </div>
                  <div class="admin-campo">
                    <label for="adminFiltroDisponibilidade">Status</label>
                    <select id="adminFiltroDisponibilidade">
                      <option value="">Todos</option>
                      <option value="disponivel">Disponíveis</option>
                      <option value="indisponivel">Indisponíveis</option>
                    </select>
                  </div>
                </div>
                <p id="adminResumoFiltro" class="admin-resumo-filtro" role="status">Mostrando todos os itens.</p>
              </section>

              <section class="admin-lista-area" aria-label="Lista de produtos cadastrados">
                <h4 class="admin-secao-titulo">Produtos</h4>
                <ul id="adminListaProdutos" class="admin-lista"></ul>
              </section>
            </section>
          </div>
        </section>

        <section id="painelAdminAdicionais" class="admin-painel" data-admin-painel="adicionais" role="tabpanel"
          aria-labelledby="adminTabAdicionais" hidden>
          <section class="bloco-form admin-bloco">
            <h3 class="admin-subtitulo">Adicionais</h3>
            <p class="admin-descricao">Mantenha os adicionais padronizados para todos os produtos.</p>
            <div id="adminListaAdicionais" class="admin-lista-adicionais"></div>
            <div class="admin-grid">
              <div>
                <label for="adminNovoAdicionalNome">Novo adicional</label>
                <input type="text" id="adminNovoAdicionalNome" maxlength="40" placeholder="Ex.: Calabresa">
              </div>
              <div>
                <label for="adminNovoAdicionalPreco">Preço</label>
                <input type="number" id="adminNovoAdicionalPreco" min="0" step="0.01" placeholder="0,00">
              </div>
            </div>
            <button type="button" id="botaoAdicionarAdicional" class="botao botao-secundario">Adicionar
              adicional</button>
          </section>
        </section>

        <section id="painelAdminCombos" class="admin-painel" data-admin-painel="combos" role="tabpanel"
          aria-labelledby="adminTabCombos" hidden>
          <section class="bloco-form admin-bloco">
            <h3 class="admin-subtitulo">Configuração de Combos</h3>
            <p class="admin-descricao">Defina como os combos serão exibidos para o cliente.</p>
            <label class="checkbox-linha">
              <input type="checkbox" id="comboAtivo" checked>
              Exibir categoria Combos
            </label>
            <p class="aviso">Base do combo:</p>
            <label class="checkbox-linha">
              <input type="checkbox" id="comboBasePastel" checked>
              Pastel
            </label>
            <label class="checkbox-linha">
              <input type="checkbox" id="comboBaseHamburguer" checked>
              Hambúrguer
            </label>
