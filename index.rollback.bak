    const erroTrocoPara = document.getElementById("erroTrocoPara");
    const erroAceiteLgpd = document.getElementById("erroAceiteLgpd");

    const seletorFocoModal = [
      "a[href]",
      "button:not([disabled])",
      "input:not([disabled]):not([type=\"hidden\"])",
      "select:not([disabled])",
      "textarea:not([disabled])",
      "summary",
      "[tabindex]:not([tabindex=\"-1\"])"
    ].join(",");

    const JANELA_DESFAZER_MS = 8000;
    let adminAutenticado = false;
    let adminAbaAtual = "produtos";
    let ultimaExclusaoAdmin = null;
    let timerDesfazerAdmin = null;
    let pilhaRetornoFoco = [];

    function formatarMoeda(valor) {
      return formatadorMoeda.format(valor);
    }

    function lerStorageSeguro(chave) {
      try {
        return localStorage.getItem(chave);
      } catch {
        return null;
      }
    }

    function salvarStorageSeguro(chave, valor) {
      try {
        localStorage.setItem(chave, valor);
        return true;
      } catch {
        return false;
      }
    }

    function escaparHtml(valor) {
      return String(valor ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function obterElementosFocaveis(container) {
      return Array.from(container.querySelectorAll(seletorFocoModal))
        .filter((elemento) =>
          !elemento.closest(".oculto")
          && !elemento.closest("[hidden]")
          && !elemento.closest("[inert]"));
    }

    function modalAtivo() {
      if (painelAdmin.classList.contains("show")) {
        return painelAdmin;
      }
      if (modalConfirmacao.classList.contains("show")) {
        return modalConfirmacao;
      }
      if (caixaCarrinho.classList.contains("show")) {
        return caixaCarrinho;
      }
      return null;
    }

    function atualizarBloqueioRolagem() {
      document.body.style.overflow = modalAtivo() ? "hidden" : "auto";
    }

    function abrirModal(modal, focoPreferencial) {
      if (modal.classList.contains("show")) {
        const alvoAberto = focoPreferencial || obterElementosFocaveis(modal)[0] || modal;
        if (alvoAberto && typeof alvoAberto.focus === "function") {
          setTimeout(() => alvoAberto.focus(), 0);
        }
        return;
      }

      const ultimoFoco = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      pilhaRetornoFoco.push(ultimoFoco);
      modal.hidden = false;
      modal.inert = false;
      modal.classList.add("show");
      atualizarBloqueioRolagem();

      const alvoFoco = focoPreferencial || obterElementosFocaveis(modal)[0] || modal;
      setTimeout(() => {
        if (alvoFoco && typeof alvoFoco.focus === "function") {
          alvoFoco.focus();
        }
      }, 0);
    }

    function fecharModal(modal, fallbackFoco = null) {
      if (!modal.classList.contains("show")) {
        return;
      }

      modal.classList.remove("show");
      modal.inert = true;
      modal.hidden = true;
      atualizarBloqueioRolagem();

      const retornoFoco = pilhaRetornoFoco.pop() || fallbackFoco;
      if (retornoFoco && typeof retornoFoco.focus === "function") {
        setTimeout(() => retornoFoco.focus(), 0);
      }
    }

    function limitarFocoNoModal(evento) {
      if (evento.key !== "Tab") {
        return;
      }

      const modal = modalAtivo();
      if (!modal) {
        return;
      }

      const focaveis = obterElementosFocaveis(modal);
      if (focaveis.length === 0) {
        evento.preventDefault();
        modal.focus();
        return;
      }

      const primeiro = focaveis[0];
      const ultimo = focaveis[focaveis.length - 1];

      if (evento.shiftKey && document.activeElement === primeiro) {
        evento.preventDefault();
        ultimo.focus();
        return;
      }

      if (!evento.shiftKey && document.activeElement === ultimo) {
        evento.preventDefault();
        primeiro.focus();
      }
    }

    function obterMinutos(horaTexto) {
      const [hora, minuto] = horaTexto.split(":").map(Number);
      return (hora * 60) + minuto;
    }

    function produtoEstaDisponivel(produto) {
      return produto.disponivel !== false && !configuracaoLoja.idsIndisponiveis.includes(produto.id);
    }

    function aplicarConfigLojaNaInterface() {
      chavePixTexto.textContent = configuracaoLoja.chavePix || "-";
      pixTitularTexto.textContent = configuracaoLoja.pixTitular || "-";
      pixBancoTexto.textContent = configuracaoLoja.pixBanco || "-";
    }

    function atualizarEnderecoRetiradaUI() {
      if (!avisoRetirada) {
        return;
      }
      const enderecoSeguro = escaparHtml(configuracaoLoja.enderecoRetirada || "");
      avisoRetirada.innerHTML = `
        <strong>Retirada no local:</strong><br>
        ${enderecoSeguro}
      `;
    }

    function atualizarBairrosEntregaUI() {
      if (!bairroEntrega) {
        return;
      }
      const bairrosDisponiveis = new Set([
        ...configuracaoLoja.bairrosComEntrega,
        ...configuracaoLoja.bairrosSemEntrega
      ]);
      const opcoes = ['<option value="">Selecione a localidade</option>'];
      configuracaoLoja.bairrosComEntrega.forEach((bairro) => {
        const nomeSeguro = escaparHtml(bairro);
        opcoes.push(`<option value="${nomeSeguro}">${nomeSeguro}</option>`);
      });
      configuracaoLoja.bairrosSemEntrega.forEach((bairro) => {
        const nomeSeguro = escaparHtml(bairro);
        opcoes.push(`<option value="${nomeSeguro}">${nomeSeguro} (sem entrega)</option>`);
      });
      bairroEntrega.innerHTML = opcoes.join("");
      if (bairroEntrega.value && !bairrosDisponiveis.has(bairroEntrega.value)) {
        bairroEntrega.value = "";
      }
    }

    function atualizarAgendaHorarioUI() {
      if (!agendaHorario) {
        return;
      }
      const dias = Object.keys(horarioFuncionamento)
        .map((dia) => Number(dia))
        .filter((dia) => Number.isFinite(dia))
        .sort((a, b) => a - b);
      if (dias.length === 0) {
        agendaHorario.innerHTML = "<li class=\"agenda-mensagem\">Consulte horários.</li>";
        return;
      }
      const linhas = dias.map((dia) => {
        const agenda = horarioFuncionamento[dia];
        const nomeDia = escaparHtml(nomesDiasSemana[dia]);
        const abre = escaparHtml(agenda.abre);
        const fecha = escaparHtml(agenda.fecha);
        return `<li><span class="agenda-dia">${nomeDia}</span><span class="agenda-hora">${abre} às ${fecha}</span></li>`;
      });
      agendaHorario.innerHTML = linhas.join("");
    }

    function atualizarMapasCategorias(categorias) {
      const categoriasValidas = categorias.filter((categoria) => categoria && categoria.slug);
      categoriasDetalhes = categoriasValidas;
      categoriasCatalogo = categoriasValidas.reduce((mapa, categoria) => {
        const slug = String(categoria.slug);
        const nome = String(categoria.nome || categoria.slug);
        mapa[slug] = nome;
        return mapa;
      }, {});
      const categoriasAtivas = categoriasValidas.filter((categoria) => categoria.ativa !== false);
      categoriasOrdem = categoriasAtivas
        .slice()
        .sort((a, b) => (a.ordem ?? 0) - (b.ordem ?? 0))
        .map((categoria) => String(categoria.slug));
      categoriasProduto = categoriasAtivas
        .filter((categoria) => categoria.is_combo !== true)
        .sort((a, b) => (a.ordem ?? 0) - (b.ordem ?? 0))
        .map((categoria) => String(categoria.slug));
      const categoriaCombo = categoriasAtivas.find((categoria) => categoria.is_combo === true);
      categoriaComboSlug = categoriaCombo ? String(categoriaCombo.slug) : "combo";
    }

    function atualizarOpcoesCategoriasAdmin() {
      if (!adminCategoriaProduto || !adminFiltroCategoria) {
        return;
      }
      const opcoesProdutos = categoriasProduto
        .map((slug) => {
          const nome = categoriasCatalogo[slug] || slug;
          const slugSeguro = escaparHtml(slug);
          const nomeSeguro = escaparHtml(nome);
          return `<option value="${slugSeguro}">${nomeSeguro}</option>`;
        })
        .join("");

      adminCategoriaProduto.innerHTML = opcoesProdutos || "<option value=\"\">Sem categorias</option>";
      adminFiltroCategoria.innerHTML = `
        <option value="">Todas</option>
        ${opcoesProdutos}
      `;

      if (!categoriasProduto.includes(adminCategoriaProduto.value)) {
        adminCategoriaProduto.value = categoriasProduto[0] || "";
      }
    }

    async function carregarDadosSupabase() {
      try {
        const [
          categoriasResp,
          adicionaisResp,
          produtosResp,
          relacoesResp,
          combosResp,
          lojaResp,
          horarioResp
        ] = await Promise.all([
          supabase.from("categorias").select("*").order("ordem", { ascending: true }),
          supabase.from("adicionais").select("*").order("ordem", { ascending: true }),
          supabase.from("produtos").select("*").order("id", { ascending: true }),
          supabase.from("produto_adicionais").select("produto_id, adicional_id"),
          supabase.from("combos_config").select("*").eq("id", 1).maybeSingle(),
          supabase.from("loja_config").select("*").eq("id", 1).maybeSingle(),
          supabase.from("horario_funcionamento").select("*").order("dia_semana", { ascending: true })
        ]);

        if (categoriasResp.error || adicionaisResp.error || produtosResp.error || relacoesResp.error
          || combosResp.error || lojaResp.error || horarioResp.error) {
          console.error("Erro ao carregar dados do Supabase", {
            categorias: categoriasResp.error,
            adicionais: adicionaisResp.error,
            produtos: produtosResp.error,
            relacoes: relacoesResp.error,
            combos: combosResp.error,
            loja: lojaResp.error,
            horario: horarioResp.error
          });
          if (mensagemErro) {
            mensagemErro.textContent = "Não foi possível carregar o cardápio. Tente novamente.";
            mensagemErro.classList.remove("oculto");
          }
          return false;
        }

        const categoriasData = categoriasResp.data || [];
        atualizarMapasCategorias(categoriasData);
        atualizarOpcoesCategoriasAdmin();

        adicionaisCatalogo = (adicionaisResp.data || []).reduce((mapa, adicional) => {
          const id = String(adicional.id || "").trim();
          if (!id) {
            return mapa;
          }
          mapa[id] = {
            id,
            nome: String(adicional.nome || id),
            preco: Number(adicional.preco) || 0
          };
          return mapa;
        }, {});

        const relacoes = relacoesResp.data || [];
        const adicionaisPorProduto = new Map();
        relacoes.forEach((registro) => {
          if (!adicionaisCatalogo[registro.adicional_id]) {
            return;
          }
          if (!adicionaisPorProduto.has(registro.produto_id)) {
            adicionaisPorProduto.set(registro.produto_id, []);
          }
          adicionaisPorProduto.get(registro.produto_id).push(registro.adicional_id);
        });

        produtos = (produtosResp.data || []).map((item) => ({
          id: Number(item.id) || 0,
          nome: String(item.nome || "Item sem nome"),
          descricao: String(item.descricao || ""),
          preco: Number(item.preco) || 0,
          categoria: String(item.categoria_slug || ""),
          disponivel: item.disponivel !== false,
          adicionais: adicionaisPorProduto.get(item.id) || []
        })).filter((item) => item.id > 0);

        if (combosResp.data) {
          configuracaoCombos = {
            ativo: combosResp.data.ativo !== false,
            desconto: Math.max(0, Number(combosResp.data.desconto) || 0),
            categoriasBase: Array.isArray(combosResp.data.categorias_base)
              ? combosResp.data.categorias_base
                .map((categoria) => String(categoria))
                .filter((categoria) => categoria)
              : [],
            categoriaBebida: String(combosResp.data.categoria_bebida_slug || "")
          };
        }

        if (categoriasProduto.length > 0) {
          configuracaoCombos.categoriasBase = configuracaoCombos.categoriasBase
            .filter((categoria) => categoriasProduto.includes(categoria));
          if (configuracaoCombos.categoriasBase.length === 0) {
            configuracaoCombos.categoriasBase = [categoriasProduto[0]];
          }
        }

        if (!configuracaoCombos.categoriaBebida) {
          configuracaoCombos.categoriaBebida = categoriasProduto.find((slug) => slug === "refrigerante")
            || categoriasProduto[0]
            || "";
        }

        if (lojaResp.data) {
          configuracaoLoja = {
            numeroWhatsApp: String(lojaResp.data.numero_whatsapp || ""),
            chavePix: String(lojaResp.data.chave_pix || ""),
            pixTitular: String(lojaResp.data.pix_titular || ""),
            pixBanco: String(lojaResp.data.pix_banco || ""),
            taxaEntrega: Number(lojaResp.data.taxa_entrega) || 0,
            enderecoRetirada: String(lojaResp.data.endereco_retirada || ""),
            bairrosComEntrega: Array.isArray(lojaResp.data.bairros_com_entrega)
              ? lojaResp.data.bairros_com_entrega.map((bairro) => String(bairro))
              : [],
            bairrosSemEntrega: Array.isArray(lojaResp.data.bairros_sem_entrega)
              ? lojaResp.data.bairros_sem_entrega.map((bairro) => String(bairro))
              : [],
            idsIndisponiveis: Array.isArray(lojaResp.data.ids_indisponiveis)
              ? lojaResp.data.ids_indisponiveis
                .map((id) => Number(id))
                .filter((id) => Number.isFinite(id))
              : []
          };
        }

        horarioFuncionamento = {};
        (horarioResp.data || []).forEach((registro) => {
          if (registro.ativo === false) {
            return;
          }
          const abre = String(registro.abre || "").slice(0, 5);
          const fecha = String(registro.fecha || "").slice(0, 5);
          if (abre && fecha) {
            horarioFuncionamento[registro.dia_semana] = { abre, fecha };
          }
        });

        aplicarConfigLojaNaInterface();
        atualizarEnderecoRetiradaUI();
        atualizarBairrosEntregaUI();
        atualizarAgendaHorarioUI();
        return true;
      } catch (erro) {
        console.error("Erro inesperado ao carregar dados", erro);
        if (mensagemErro) {
          mensagemErro.textContent = "Não foi possível carregar o cardápio. Tente novamente.";
          mensagemErro.classList.remove("oculto");
        }
        return false;
      }
    }

    const REALTIME_DEBOUNCE_MS = 400;
    let realtimeTimer = null;
    let realtimeChannel = null;
    let realtimePendente = false;
    let adminEdicaoAtiva = false;

    function adminTemFocoEmEdicao() {
      if (!adminAutenticado || !painelAdmin.classList.contains("show")) {
        return false;
      }
      const ativo = document.activeElement;
      if (!ativo || !painelAdmin.contains(ativo)) {
        return false;
      }
      const tag = ativo.tagName ? ativo.tagName.toLowerCase() : "";
      return tag === "input" || tag === "textarea" || tag === "select";
    }

    function podeAtualizarRealtimeAgora() {
      if (!adminAutenticado) {
        return true;
      }
      if (!painelAdmin.classList.contains("show")) {
        return true;
      }
      if (adminEdicaoAtiva || adminTemFocoEmEdicao()) {
        return false;
      }
      return true;
    }

    function finalizarEdicaoAdmin() {
      adminEdicaoAtiva = false;
      if (realtimePendente && podeAtualizarRealtimeAgora()) {
        realtimePendente = false;
        agendarAtualizacaoRealtime();
      }
    }

    async function atualizarInterfaceAposDados() {
      renderizarCategorias();
      mostrarProdutos();
      atualizarCarrinho();
      atualizarStatusLoja();
      atualizarBotoesBloqueio();

      if (atendimentoAtual() === "delivery" && tipoEntrega.value === "entrega") {
        atualizarTaxaInfo();
      }

      if (adminAutenticado) {
        renderizarChecklistAdicionaisAdmin();
        renderizarListaProdutosAdmin({ resetarRolagem: true });
        renderizarListaAdicionaisAdmin();
        preencherConfigCombosAdmin();
        atualizarResumoAdmin();
        ativarAbaAdmin(adminAbaAtual);
      }
    }

    function agendarAtualizacaoRealtime() {
      if (!podeAtualizarRealtimeAgora()) {
        realtimePendente = true;
        return;
      }
      if (realtimeTimer) {
        clearTimeout(realtimeTimer);
      }
      realtimeTimer = setTimeout(async () => {
        const ok = await carregarDadosSupabase();
        if (ok) {
          atualizarInterfaceAposDados();
        }
      }, REALTIME_DEBOUNCE_MS);
    }

    function iniciarRealtime() {
      if (realtimeChannel) {
        realtimeChannel.unsubscribe();
      }
      realtimeChannel = supabase
        .channel("cardapio-realtime")
        .on("postgres_changes", { event: "*", schema: "public", table: "categorias" }, agendarAtualizacaoRealtime)
        .on("postgres_changes", { event: "*", schema: "public", table: "adicionais" }, agendarAtualizacaoRealtime)
        .on("postgres_changes", { event: "*", schema: "public", table: "produtos" }, agendarAtualizacaoRealtime)
        .on("postgres_changes", { event: "*", schema: "public", table: "produto_adicionais" }, agendarAtualizacaoRealtime)
        .on("postgres_changes", { event: "*", schema: "public", table: "combos_config" }, agendarAtualizacaoRealtime)
        .on("postgres_changes", { event: "*", schema: "public", table: "loja_config" }, agendarAtualizacaoRealtime)
        .on("postgres_changes", { event: "*", schema: "public", table: "horario_funcionamento" }, agendarAtualizacaoRealtime)
        .subscribe();
    }

    function obterCategoriasDisponiveis() {
      const categorias = [];
      const produtosDisponiveis = new Set(produtos.map((produto) => produto.categoria));
      const possuiBebida = produtos.some((produto) =>
        produto.categoria === configuracaoCombos.categoriaBebida && produtoEstaDisponivel(produto));
      const possuiBase = configuracaoCombos.categoriasBase.some((categoriaBase) =>
        produtos.some((produto) => produto.categoria === categoriaBase && produtoEstaDisponivel(produto)));

      if (configuracaoCombos.ativo && possuiBebida && possuiBase) {
        categorias.push(categoriaComboSlug);
      }

      categoriasProduto.forEach((categoria) => {
        if (produtosDisponiveis.has(categoria)) {
          categorias.push(categoria);
        }
      });

      return categorias;
    }

    function renderizarCategorias() {
      const categorias = obterCategoriasDisponiveis();
      if (!categorias.includes(categoriaAtual)) {
        categoriaAtual = categorias[0] || "";
      }

      menuCategorias.innerHTML = categorias
        .map((categoria) => {
          const categoriaSegura = escaparHtml(categoria);
          const nomeCategoria = categoriasCatalogo[categoria] || categoria;
          const nomeSeguro = escaparHtml(nomeCategoria);
          return `
          <button class="categoria ${categoria === categoriaAtual ? "ativa" : ""}" data-categoria="${categoriaSegura}" type="button" aria-pressed="${categoria === categoriaAtual ? "true" : "false"}">
            ${nomeSeguro}
          </button>
        `;
        })
        .join("");
    }

    function obterProdutoPorId(id) {
      return produtos.find((produto) => String(produto.id) === String(id));
    }

    function slugify(texto) {
      return texto
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, "_")
        .replace(/^_+|_+$/g, "");
    }

    function calcularPrecoCombo(itemBase, bebida) {
      const bruto = itemBase.preco + bebida.preco;
      return Math.max(0, bruto - (Number(configuracaoCombos.desconto) || 0));
    }

    function obterStatusLoja(dataAtual = new Date()) {
      const diaAtual = dataAtual.getDay();
      const agendaHoje = horarioFuncionamento[diaAtual];
      const minutosAgora = (dataAtual.getHours() * 60) + dataAtual.getMinutes();

      if (!agendaHoje) {
        return {
          aberta: false,
          mensagem: "Loja fechada hoje",
          detalhe: "Sem atendimento hoje"
        };
      }

      const abre = obterMinutos(agendaHoje.abre);
      const fecha = obterMinutos(agendaHoje.fecha);
      if (minutosAgora >= abre && minutosAgora <= fecha) {
        return {
          aberta: true,
          mensagem: "Aberto agora",
          detalhe: `Hoje até ${agendaHoje.fecha}`
        };
      }

      let proximaAbertura = "";
      if (minutosAgora < abre) {
        proximaAbertura = `Abre hoje às ${agendaHoje.abre}`;
      } else {
        for (let deslocamento = 1; deslocamento <= 7; deslocamento += 1) {
          const proximoDia = (diaAtual + deslocamento) % 7;
          const agendaDia = horarioFuncionamento[proximoDia];
          if (!agendaDia) {
            continue;
          }
          if (deslocamento === 1) {
            proximaAbertura = `Abre amanhã às ${agendaDia.abre}`;
          } else {
            proximaAbertura = `Abre ${nomesDiasSemana[proximoDia]} às ${agendaDia.abre}`;
          }
          break;
        }
      }

      return {
        aberta: false,
        mensagem: "Fechado no momento",
        detalhe: proximaAbertura || "Sem horário disponível"
      };
    }

    function atualizarStatusLoja() {
      const status = obterStatusLoja();
      statusLoja.className = `status-loja ${status.aberta ? "status-aberta" : "status-fechada"}`;
      statusLoja.textContent = status.mensagem;
      detalheHorario.textContent = status.detalhe;
    }

    function atendimentoAtual() {
      return document.querySelector('input[name="tipoAtendimento"]:checked').value;
    }

    function obterExtrasDoCard(card) {
      return Array.from(card.querySelectorAll("input[data-extra]:checked")).map((inputExtra) => ({
        id: inputExtra.dataset.extra,
        nome: inputExtra.dataset.nome,
        preco: Number(inputExtra.dataset.preco)
      }));
    }

    function gerarChaveCarrinho(produtoId, extras, observacaoItem) {
      const chaveExtras = extras.map((extra) => extra.id).sort().join(",");
      const chaveObs = observacaoItem.trim().toLowerCase();
      return `${produtoId}|${chaveExtras}|${chaveObs}`;
    }

    function precoUnitarioItem(item) {
      const totalExtras = item.extras.reduce((acumulador, extra) => acumulador + extra.preco, 0);
      return item.precoBase + totalExtras;
    }

    function subtotalCarrinho() {
      return carrinho.reduce((acumulador, item) => acumulador + (precoUnitarioItem(item) * item.quantidade), 0);
    }

    function calcularTaxaEntregaAtual() {
      if (atendimentoAtual() !== "delivery" || tipoEntrega.value !== "entrega") {
        return 0;
      }
      return configuracaoLoja.bairrosComEntrega.includes(bairroEntrega.value) ? configuracaoLoja.taxaEntrega : 0;
    }

    function calcularTotaisPedido() {
      const subtotal = subtotalCarrinho();
      const taxa = calcularTaxaEntregaAtual();
      return {
        subtotal,
        taxa,
        total: subtotal + taxa
      };
    }

    function atualizarResumoValores() {
      const { subtotal, taxa, total } = calcularTotaisPedido();
      const quantidadeTotal = carrinho.reduce((acumulador, item) => acumulador + item.quantidade, 0);
      resumoPedido.innerHTML = `
        <span class="resumo-linha">
          <span>Subtotal</span>
          <strong>${formatarMoeda(subtotal)}</strong>
        </span>
        <span class="resumo-linha">
          <span>Taxa de entrega</span>
          <strong>${formatarMoeda(taxa)}</strong>
        </span>
      `;
      valorTotal.innerHTML = `
        <span>Total</span>
        <strong>${formatarMoeda(total)}</strong>
      `;
      totalBarraMobile.textContent = formatarMoeda(total);
      contadorCarrinho.textContent = quantidadeTotal;
      carrinhoSubtitulo.textContent = quantidadeTotal === 0
        ? "Seu carrinho está vazio."
        : `${quantidadeTotal} item${quantidadeTotal > 1 ? "s" : ""} no carrinho.`;
      resumoTopoItens.textContent = `Itens: ${quantidadeTotal} item${quantidadeTotal > 1 ? "s" : ""}`;
      resumoTopoSubtotal.textContent = `Subtotal: ${formatarMoeda(subtotal)}`;
      atualizarBotoesBloqueio();
      return { subtotal, taxa, total };
    }

    function limparErro() {
      mensagemErro.textContent = "";
      mensagemErro.classList.add("oculto");
    }

    function mostrarErro(texto, moverFoco = false) {
      mensagemErro.textContent = texto;
      mensagemErro.classList.remove("oculto");
      if (moverFoco) {
        mensagemErro.focus();
      }
    }

    function limparErroCampo(campo) {
      if (!campo) {
        return;
      }
      campo.removeAttribute("aria-invalid");
      const idErro = campo.dataset.erroId;
      if (!idErro) {
        return;
      }
      const caixaErro = document.getElementById(idErro);
      if (caixaErro) {
        caixaErro.textContent = "";
        caixaErro.classList.add("oculto");
      }
    }

    function limparErrosCampos() {
      [tipoEntrega, bairroEntrega, enderecoEntrega, numeroMesa, nome, telefone, pagamento, trocoPara, aceiteLgpd]
        .forEach((campo) => limparErroCampo(campo));
    }

    function marcarErroCampo(campo, caixaErro, mensagem) {
      if (campo) {
        campo.setAttribute("aria-invalid", "true");
      }
      if (caixaErro) {
        caixaErro.textContent = mensagem;
        caixaErro.classList.remove("oculto");
      }
    }

    function anunciarCategoriaExibida() {
      if (!statusCategoria) {
        return;
      }
      const categoria = categoriasCatalogo[categoriaAtual] || categoriaAtual;
      const totalOpcoes = areaProdutos.querySelectorAll(".produto-card").length;
      statusCategoria.textContent = `${categoria} selecionada. ${totalOpcoes} opção${totalOpcoes === 1 ? "" : "ões"} exibida${totalOpcoes === 1 ? "" : "s"}.`;
    }

    function renderizarCabecalhoCategoria(titulo, quantidadeItens) {
      const cabecalho = document.createElement("section");
      cabecalho.className = "cabecalho-categoria";
      const plural = quantidadeItens === 1 ? "item" : "itens";
      cabecalho.innerHTML = `
        <h2>${escaparHtml(titulo)}</h2>
        <p>${quantidadeItens} ${plural} no cardapio.</p>
      `;
      areaProdutos.appendChild(cabecalho);
    }

    function aplicarFeedbackBotaoAdicionar(botao, textoTemporario = "Adicionado \u2713") {
      if (!botao || botao.disabled) {
        return;
      }
      const labelOriginal = botao.dataset.labelDefault || botao.textContent.trim() || "Adicionar";
      botao.dataset.labelDefault = labelOriginal;
      botao.classList.add("is-added");
      botao.textContent = textoTemporario;
      botao.disabled = true;

      const timerAnterior = Number(botao.dataset.feedbackTimer || "0");
      if (timerAnterior) {
        clearTimeout(timerAnterior);
      }

      const timer = window.setTimeout(() => {
        botao.classList.remove("is-added");
        botao.textContent = labelOriginal;
        botao.disabled = botao.hasAttribute("aria-disabled");
        delete botao.dataset.feedbackTimer;
      }, 900);

      botao.dataset.feedbackTimer = String(timer);
    }

    function salvarCarrinhoLocal() {
      salvarStorageSeguro(CHAVE_STORAGE_CARRINHO, JSON.stringify(carrinho));
    }

    function salvarFormularioLocal() {
      const estado = {
        tipoAtendimento: atendimentoAtual(),
        tipoEntrega: tipoEntrega.value,
        bairroEntrega: bairroEntrega.value,
        enderecoEntrega: enderecoEntrega.value,
        referencia: referencia.value,
        numeroMesa: numeroMesa.value,
        nome: nome.value,
        telefone: telefone.value,
        pagamento: pagamento.value,
        precisaTroco: precisaTroco.checked,
        trocoPara: trocoPara.value,
        observacoes: observacoes.value,
        aceiteLgpd: aceiteLgpd.checked
      };
      salvarStorageSeguro(CHAVE_STORAGE_FORMULARIO, JSON.stringify(estado));
    }

    function restaurarCarrinhoLocal() {
      try {
        const dados = JSON.parse(lerStorageSeguro(CHAVE_STORAGE_CARRINHO) || "[]");
        if (Array.isArray(dados)) {
          carrinho = dados;
        }
      } catch {
        carrinho = [];
      }
    }

    function restaurarFormularioLocal() {
      try {
        const estado = JSON.parse(lerStorageSeguro(CHAVE_STORAGE_FORMULARIO) || "{}");
        if (!estado || typeof estado !== "object") {
          return;
        }

        if (estado.tipoAtendimento === "no_local") {
          const radioNoLocal = document.querySelector('input[name="tipoAtendimento"][value="no_local"]');
          if (radioNoLocal) {
            radioNoLocal.checked = true;
          }
        }

        tipoEntrega.value = estado.tipoEntrega || "";
        bairroEntrega.value = estado.bairroEntrega || "";
        enderecoEntrega.value = estado.enderecoEntrega || "";
        referencia.value = estado.referencia || "";
        numeroMesa.value = estado.numeroMesa || "";
        nome.value = estado.nome || "";
        telefone.value = estado.telefone || "";
        pagamento.value = estado.pagamento || "";
        precisaTroco.checked = Boolean(estado.precisaTroco);
        trocoPara.value = estado.trocoPara || "";
        observacoes.value = estado.observacoes || "";
        aceiteLgpd.checked = Boolean(estado.aceiteLgpd);
      } catch {
        // Sem restauração
      }
    }

    function criarCardProduto(produto) {
      const disponivel = produtoEstaDisponivel(produto);
      const adicionais = (produto.adicionais || [])
        .map((idAdicional) => adicionaisCatalogo[idAdicional])
        .filter(Boolean);
      const nomeProdutoSeguro = escaparHtml(produto.nome);
      const descricaoProdutoSegura = escaparHtml(produto.descricao);

      const htmlAdicionais = adicionais
        .map((adicional) => {
          const idExtra = escaparHtml(adicional.id);
          const nomeExtra = escaparHtml(adicional.nome);
          return `
            <label class="checkbox-linha add-on-item">
              <input
                type="checkbox"
                data-extra="${idExtra}"
                data-nome="${nomeExtra}"
                data-preco="${adicional.preco}"
              />
              ${nomeExtra} (+${formatarMoeda(adicional.preco)})
            </label>
          `;
        })
        .join("");

      const personalizacao = disponivel
        ? `
          <details class="personalizacao">
            <summary>Personalizar item</summary>
            <div class="add-on-list">
              ${htmlAdicionais || '<p class="aviso">Sem adicionais para este item.</p>'}
            </div>
            <label for="obs-item-${produto.id}">Observação deste item:</label>
            <input id="obs-item-${produto.id}" class="obs-item" type="text" maxlength="70" placeholder="Opcional" />
          </details>
        `
        : '<p class="aviso aviso-indisponivel">Item indisponível no momento.</p>';

      const card = document.createElement("article");
      card.className = "produto-card";
      card.innerHTML = `
        <div class="produto-conteudo">
          <div class="produto-topo">
            <h3>${nomeProdutoSeguro}</h3>
            ${!disponivel ? '<span class="badge-esgotado">Esgotado</span>' : ""}
          </div>
          <p class="produto-descricao">${descricaoProdutoSegura}</p>
          ${personalizacao}
        </div>
        <div class="produto-rodape">
          <span class="preco-produto">${formatarMoeda(produto.preco)}</span>
          <button class="botao botao-principal botao-adicionar" data-id="${produto.id}" data-label-default="${disponivel ? "Adicionar" : "Indisponivel"}" type="button" ${!disponivel ? "disabled aria-disabled=\"true\"" : ""}>
            ${disponivel ? "Adicionar" : "Indisponivel"}
          </button>
        </div>
      `;
      return card;
    }

    function atualizarPrecoCardCombo(card) {
      const baseSelect = card.querySelector(".combo-base");
      const bebidaSelect = card.querySelector(".combo-bebida");
      const precoLabel = card.querySelector(".combo-preco");
      const botao = card.querySelector(".botao-adicionar-combo");

      const itemBase = obterProdutoPorId(baseSelect.value);
      const bebida = obterProdutoPorId(bebidaSelect.value);
      const ambosSelecionados = Boolean(itemBase && bebida);

      if (!ambosSelecionados) {
        precoLabel.textContent = "Selecione os itens para ver o valor do combo.";
        botao.disabled = true;
        botao.setAttribute("aria-disabled", "true");
        return;
      }

      const precoCombo = calcularPrecoCombo(itemBase, bebida);
      precoLabel.textContent = `Total do combo: ${formatarMoeda(precoCombo)}${configuracaoCombos.desconto > 0 ? ` (desconto de ${formatarMoeda(configuracaoCombos.desconto)})` : ""}`;
      botao.disabled = false;
      botao.removeAttribute("aria-disabled");
    }

    function mostrarCombos() {
      areaProdutos.innerHTML = "";
      const bebidas = produtos.filter((produto) => produto.categoria === configuracaoCombos.categoriaBebida && produtoEstaDisponivel(produto));
      let totalCombos = 0;
      const cardsCombo = [];

      configuracaoCombos.categoriasBase.forEach((categoriaBase) => {
        const bases = produtos.filter((produto) => produto.categoria === categoriaBase && produtoEstaDisponivel(produto));
        if (bases.length === 0 || bebidas.length === 0) {
          return;
        }

        const nomeCategoriaBase = escaparHtml(categoriasCatalogo[categoriaBase] || categoriaBase);
        const nomeCategoriaBebida = escaparHtml(categoriasCatalogo[configuracaoCombos.categoriaBebida] || configuracaoCombos.categoriaBebida);
        const categoriaBaseSegura = escaparHtml(categoriaBase);

        const card = document.createElement("article");
        card.className = "produto-card combo-card";
        card.innerHTML = `
          <div class="produto-conteudo">
            <div class="produto-topo">
              <h3>Combo ${nomeCategoriaBase} + ${nomeCategoriaBebida}</h3>
            </div>
            <p class="produto-descricao">Escolha 1 item base e 1 bebida para montar o combo.</p>
            <label class="combo-label">Item base:</label>
            <select class="combo-base combo-select">
              <option value="">Selecione</option>
              ${bases.map((produto) => `<option value="${produto.id}">${escaparHtml(produto.nome)} (${formatarMoeda(produto.preco)})</option>`).join("")}
            </select>
            <label class="combo-label">Bebida:</label>
            <select class="combo-bebida combo-select">
              <option value="">Selecione</option>
              ${bebidas.map((produto) => `<option value="${produto.id}">${escaparHtml(produto.nome)} (${formatarMoeda(produto.preco)})</option>`).join("")}
            </select>
            <p class="preco-produto combo-preco"></p>
          </div>
          <div class="produto-rodape">
            <button class="botao botao-principal botao-adicionar-combo" data-label-default="Adicionar combo" type="button" data-base-categoria="${categoriaBaseSegura}" disabled aria-disabled="true">
              Adicionar combo
            </button>
          </div>
        `;
        cardsCombo.push(card);
        totalCombos += 1;
        atualizarPrecoCardCombo(card);
      });

      const tituloCombo = categoriasCatalogo[categoriaComboSlug] || "Combos";
      renderizarCabecalhoCategoria(tituloCombo, totalCombos);

      if (cardsCombo.length === 0) {
        const vazio = document.createElement("article");
        vazio.className = "produto-card";
        const nomeBebida = categoriasCatalogo[configuracaoCombos.categoriaBebida] || "bebidas";
        vazio.innerHTML = `
          <h3>Combos indisponíveis</h3>
          <p>Cadastre itens base e ${escaparHtml(nomeBebida.toLowerCase())} no painel administrativo para ativar os combos.</p>
        `;
        areaProdutos.appendChild(vazio);
      } else {
        cardsCombo.forEach((card) => areaProdutos.appendChild(card));
      }

      anunciarCategoriaExibida();
    }

    function mostrarProdutos() {
      areaProdutos.innerHTML = "";

      if (!categoriaAtual) {
        const vazio = document.createElement("article");
        vazio.className = "produto-card";
        vazio.innerHTML = "<p>Cardápio indisponível no momento.</p>";
        areaProdutos.appendChild(vazio);
        return;
      }

      if (categoriaAtual === categoriaComboSlug) {
        mostrarCombos();
        return;
      }

      const itensDaCategoria = produtos.filter((produto) => produto.categoria === categoriaAtual);
      renderizarCabecalhoCategoria(categoriasCatalogo[categoriaAtual] || categoriaAtual, itensDaCategoria.length);
      itensDaCategoria.forEach((produto) => {
        areaProdutos.appendChild(criarCardProduto(produto));
      });

      if (itensDaCategoria.length === 0) {
        const vazio = document.createElement("article");
        vazio.className = "produto-card";
        vazio.innerHTML = "<p>Nenhum item cadastrado nesta categoria.</p>";
        areaProdutos.appendChild(vazio);
      }

      anunciarCategoriaExibida();
    }

    function adicionarAoCarrinho(produto, extras, observacaoItem) {
      const chave = gerarChaveCarrinho(produto.id, extras, observacaoItem);
      const existente = carrinho.find((item) => item.chave === chave);

      if (existente) {
        existente.quantidade += 1;
      } else {
        carrinho.push({
          chave,
          produtoId: produto.id,
          nome: produto.nome,
          precoBase: produto.preco,
          extras,
          observacaoItem,
          quantidade: 1
        });
      }

      atualizarCarrinho();
      salvarCarrinhoLocal();
    }

    function alterarQuantidade(chave, delta) {
      const item = carrinho.find((registro) => registro.chave === chave);
      if (!item) {
        return;
      }

      item.quantidade += delta;
      if (item.quantidade <= 0) {
        carrinho = carrinho.filter((registro) => registro.chave !== chave);
      }

      atualizarCarrinho();
      salvarCarrinhoLocal();
    }

    function removerItem(chave) {
      carrinho = carrinho.filter((item) => item.chave !== chave);
      atualizarCarrinho();
      salvarCarrinhoLocal();
    }

    function atualizarCarrinho() {
      listaCarrinho.innerHTML = "";

      if (carrinho.length === 0) {
        const vazio = document.createElement("li");
        vazio.className = "item-vazio";
        vazio.textContent = "Seu carrinho está vazio.";
        listaCarrinho.appendChild(vazio);
      }

      carrinho.forEach((item) => {
        const totalItem = precoUnitarioItem(item) * item.quantidade;
        const detalhes = [];
        const nomeItemSeguro = escaparHtml(item.nome);

        if (item.extras.length > 0) {
          detalhes.push(`Adicionais: ${item.extras.map((extra) => escaparHtml(extra.nome)).join(", ")}`);
        }
        if (item.observacaoItem) {
          detalhes.push(`Obs: ${escaparHtml(item.observacaoItem)}`);
        }

        const li = document.createElement("li");
        li.className = "item-carrinho";
        li.innerHTML = `
          <div class="item-linha">
            <div class="item-descricao">
              <strong>${nomeItemSeguro}</strong>
              ${detalhes.length > 0 ? `<p class="item-detalhes">${detalhes.join(" · ")}</p>` : ""}
            </div>
            <span class="item-valor">${formatarMoeda(totalItem)}</span>
          </div>
          <div class="controles-item">
            <button type="button" class="btn-mini" data-acao="menos" data-chave="${item.chave}" aria-label="Diminuir quantidade">-</button>
            <span class="quantidade-item" aria-live="polite">${item.quantidade}</span>
            <button type="button" class="btn-mini" data-acao="mais" data-chave="${item.chave}" aria-label="Aumentar quantidade">+</button>
            <button type="button" class="btn-remover" data-acao="remover" data-chave="${item.chave}">Remover</button>
          </div>
        `;
        listaCarrinho.appendChild(li);
      });

      atualizarResumoValores();
    }

    function atualizarFluxoAtendimento() {
      const tipo = atendimentoAtual();
      const isDelivery = tipo === "delivery";

      blocoDelivery.classList.toggle("oculto", !isDelivery);
      blocoNoLocal.classList.toggle("oculto", isDelivery);
      blocoTelefone.classList.toggle("oculto", !isDelivery);

      tipoEntrega.required = isDelivery;
      numeroMesa.required = !isDelivery;
      telefone.required = isDelivery;

      if (!isDelivery) {
        tipoEntrega.value = "";
        camposEntrega.classList.add("oculto");
        enderecoRetiradaBox.classList.add("oculto");
        bairroEntrega.value = "";
        enderecoEntrega.value = "";
        limparErroCampo(tipoEntrega);
        limparErroCampo(bairroEntrega);
        limparErroCampo(enderecoEntrega);
        limparErroCampo(telefone);
      } else {
        limparErroCampo(numeroMesa);
      }

      atualizarVisibilidadeEntrega();
      atualizarResumoValores();
      salvarFormularioLocal();
    }

    function atualizarTaxaInfo() {
      const bairro = bairroEntrega.value;

      if (!bairro) {
        const bairrosTexto = configuracaoLoja.bairrosComEntrega.length > 0
          ? configuracaoLoja.bairrosComEntrega.join(", ")
          : "localidades disponíveis";
        taxaEntregaInfo.textContent = `Taxa para ${bairrosTexto}: ${formatarMoeda(configuracaoLoja.taxaEntrega)}.`;
        bloqueioEntregaInfo.classList.add("oculto");
        return;
      }

      if (configuracaoLoja.bairrosComEntrega.includes(bairro)) {
        taxaEntregaInfo.textContent = `Localidade atendida: ${bairro}. Taxa de entrega: ${formatarMoeda(configuracaoLoja.taxaEntrega)}.`;
        bloqueioEntregaInfo.classList.add("oculto");
        return;
      }

      if (configuracaoLoja.bairrosSemEntrega.includes(bairro)) {
        taxaEntregaInfo.textContent = "";
        bloqueioEntregaInfo.textContent = `Não fazemos entrega em ${bairro}. Selecione retirada no local.`;
        bloqueioEntregaInfo.classList.remove("oculto");
        return;
      }

      taxaEntregaInfo.textContent = "";
      bloqueioEntregaInfo.classList.add("oculto");
    }

    function atualizarVisibilidadeEntrega() {
      const isDelivery = atendimentoAtual() === "delivery";
      const escolha = tipoEntrega.value;
      const isEntrega = isDelivery && escolha === "entrega";
      const isRetirada = isDelivery && escolha === "retirada";

      camposEntrega.classList.toggle("oculto", !isEntrega);
      enderecoRetiradaBox.classList.toggle("oculto", !isRetirada);

      bairroEntrega.required = isEntrega;
      enderecoEntrega.required = isEntrega;

      if (!isEntrega) {
        taxaEntregaInfo.textContent = "";
        bloqueioEntregaInfo.classList.add("oculto");
        limparErroCampo(bairroEntrega);
        limparErroCampo(enderecoEntrega);
      } else {
        atualizarTaxaInfo();
      }

      atualizarResumoValores();
      salvarFormularioLocal();
    }

    function atualizarBlocosPagamento() {
      const metodo = pagamento.value;
      const mostrarPix = metodo === "Pix";
      const mostrarTroco = metodo === "Dinheiro";

      pixInfo.classList.toggle("oculto", !mostrarPix);
      trocoInfo.classList.toggle("oculto", !mostrarTroco);

      if (!mostrarTroco) {
        precisaTroco.checked = false;
        trocoPara.value = "";
        trocoPara.required = false;
        trocoParaBox.classList.add("oculto");
        limparErroCampo(trocoPara);
      } else {
        trocoParaBox.classList.toggle("oculto", !precisaTroco.checked);
        trocoPara.required = precisaTroco.checked;
      }

      salvarFormularioLocal();
    }

    function copiarChavePix() {
      const chave = String(configuracaoLoja.chavePix || "").trim();
      mensagemCopiaPix.classList.add("oculto");
      mensagemErroCopiaPix.classList.add("oculto");

      if (!navigator.clipboard || !window.isSecureContext) {
        mensagemErroCopiaPix.textContent = `Não foi possível copiar automaticamente. Copie manualmente: ${chave}`;
        mensagemErroCopiaPix.classList.remove("oculto");
        return;
      }

      navigator.clipboard.writeText(chave)
        .then(() => {
          mensagemCopiaPix.classList.remove("oculto");
          setTimeout(() => mensagemCopiaPix.classList.add("oculto"), 2500);
        })
        .catch(() => {
          mensagemErroCopiaPix.textContent = `Não foi possível copiar automaticamente. Copie manualmente: ${chave}`;
          mensagemErroCopiaPix.classList.remove("oculto");
        });
    }

    let alturaViewportBase = window.innerHeight;

    function focoEmCampoCarrinho() {
      const ativo = document.activeElement;
      if (!ativo || !caixaCarrinho.contains(ativo)) {
        return false;
      }
      if (ativo.isContentEditable) {
        return true;
      }
      const tag = ativo.tagName ? ativo.tagName.toLowerCase() : "";
      return tag === "input" || tag === "textarea" || tag === "select";
    }

    function tecladoVisivel() {
      if (!focoEmCampoCarrinho()) {
        alturaViewportBase = window.innerHeight;
        return false;
      }

      if (window.visualViewport) {
        const diferenca = window.innerHeight - window.visualViewport.height;
        return diferenca > 120;
      }

      const diferenca = alturaViewportBase - window.innerHeight;
      return diferenca > 120;
    }

    function atualizarEstadoTecladoCarrinho() {
      if (!caixaCarrinho.classList.contains("show")) {
        caixaCarrinhoConteudo.classList.remove("teclado-ativo");
        return;
      }
      if (!mediaTecladoMobile.matches) {
        caixaCarrinhoConteudo.classList.remove("teclado-ativo");
        return;
      }
      caixaCarrinhoConteudo.classList.toggle("teclado-ativo", tecladoVisivel());
    }

    function abrirCarrinho() {
      abrirModal(caixaCarrinho, botaoFechar);
      botaoCarrinho.setAttribute("aria-expanded", "true");
      botaoAbrirCarrinhoMobile.setAttribute("aria-expanded", "true");
      alturaViewportBase = window.innerHeight;
      atualizarEstadoTecladoCarrinho();
      limparErro();
    }

    function fecharCarrinho() {
      fecharModal(caixaCarrinho, botaoCarrinho);
      botaoCarrinho.setAttribute("aria-expanded", "false");
      botaoAbrirCarrinhoMobile.setAttribute("aria-expanded", "false");
      caixaCarrinhoConteudo.classList.remove("teclado-ativo");
    }

    function abrirConfirmacao(textoResumo) {
      resumoConfirmacao.textContent = textoResumo;
      abrirModal(modalConfirmacao, botaoConfirmarEnvio);
    }

    function fecharConfirmacao() {
      fecharModal(modalConfirmacao, botaoFinalizar);
    }

    function dataCompactaLocal(data) {
      const ano = data.getFullYear();
      const mes = String(data.getMonth() + 1).padStart(2, "0");
      const dia = String(data.getDate()).padStart(2, "0");
      return `${ano}${mes}${dia}`;
    }

    function gerarNumeroPedido() {
      const hoje = dataCompactaLocal(new Date());
      const chaveDia = `${CHAVE_SEQUENCIA_PEDIDO}${hoje}`;
      const sequenciaStorage = Number(lerStorageSeguro(chaveDia) || "0");
      let sequencia = Number.isFinite(sequenciaStorage) && sequenciaStorage > 0 ? sequenciaStorage + 1 : 1;
      const salvo = salvarStorageSeguro(chaveDia, String(sequencia));
      if (!salvo) {
        const sequenciaMemoria = Number(sequenciaPedidoMemoria[chaveDia] || 0) + 1;
        sequenciaPedidoMemoria[chaveDia] = sequenciaMemoria;
        sequencia = sequenciaMemoria;
      }
      return `TL-${hoje.slice(2)}-${String(sequencia).padStart(3, "0")}`;
    }

    function validarTelefone(valor) {
      const digitos = valor.replace(/\D/g, "");
      return digitos.length === 10 || digitos.length === 11;
    }

    function aplicarMascaraTelefone(valor) {
      const digitos = valor.replace(/\D/g, "").slice(0, 11);
      if (digitos.length <= 2) {
        return digitos;
      }
      if (digitos.length <= 6) {
        return `(${digitos.slice(0, 2)}) ${digitos.slice(2)}`;
      }
      if (digitos.length <= 10) {
        return `(${digitos.slice(0, 2)}) ${digitos.slice(2, 6)}-${digitos.slice(6)}`;
      }
      return `(${digitos.slice(0, 2)}) ${digitos.slice(2, 7)}-${digitos.slice(7)}`;
    }

    function validarFormulario() {
      limparErrosCampos();
      const tipoAtendimento = atendimentoAtual();
      const tipoPedido = tipoEntrega.value;
      const { total } = calcularTotaisPedido();

      if (carrinho.length === 0) {
        return { mensagem: "Adicione pelo menos um item ao carrinho.", campo: null };
      }
      if (!nome.value.trim()) {
        marcarErroCampo(nome, erroNome, "Informe o nome completo.");
        return { mensagem: "Preencha o nome completo.", campo: nome };
      }
      if (tipoAtendimento !== "no_local" && !telefone.value.trim()) {
        marcarErroCampo(telefone, erroTelefone, "Informe o telefone com DDD.");
        return { mensagem: "Preencha o telefone ou WhatsApp.", campo: telefone };
      }
      if (telefone.value.trim() && !validarTelefone(telefone.value.trim())) {
        marcarErroCampo(telefone, erroTelefone, "Formato inválido. Use DDD + número.");
        return { mensagem: "Informe um telefone ou WhatsApp válido com DDD.", campo: telefone };
      }
      if (!pagamento.value) {
        marcarErroCampo(pagamento, erroPagamento, "Selecione uma forma de pagamento.");
        return { mensagem: "Selecione a forma de pagamento.", campo: pagamento };
      }
      if (!aceiteLgpd.checked) {
        marcarErroCampo(aceiteLgpd, erroAceiteLgpd, "Confirme o consentimento para continuar.");
        return { mensagem: "É necessário aceitar o consentimento de dados para finalizar.", campo: aceiteLgpd };
      }

      if (pagamento.value === "Dinheiro" && precisaTroco.checked) {
        const valorTroco = Number(String(trocoPara.value).replace(",", "."));
        if (!Number.isFinite(valorTroco) || valorTroco <= 0) {
          marcarErroCampo(trocoPara, erroTrocoPara, "Informe um valor válido para troco.");
          return { mensagem: "Informe um valor válido para troco.", campo: trocoPara };
        }
        if (valorTroco < total) {
          const mensagemTroco = `O troco precisa ser para um valor igual ou maior que ${formatarMoeda(total)}.`;
          marcarErroCampo(trocoPara, erroTrocoPara, mensagemTroco);
          return { mensagem: mensagemTroco, campo: trocoPara };
        }
      }

      if (tipoAtendimento === "no_local") {
        if (!numeroMesa.value || Number(numeroMesa.value) < 1) {
          marcarErroCampo(numeroMesa, erroNumeroMesa, "Informe um número de mesa válido.");
          return { mensagem: "Informe um número de mesa válido.", campo: numeroMesa };
        }
        return { mensagem: "", campo: null };
      }

      if (!tipoPedido) {
        marcarErroCampo(tipoEntrega, erroTipoEntrega, "Selecione se o pedido é entrega ou retirada.");
        return { mensagem: "Selecione se o pedido é entrega ou retirada.", campo: tipoEntrega };
      }

      if (tipoPedido === "entrega") {
        if (!bairroEntrega.value) {
          marcarErroCampo(bairroEntrega, erroBairroEntrega, "Selecione a localidade de entrega.");
          return { mensagem: "Selecione a localidade de entrega.", campo: bairroEntrega };
        }
        if (configuracaoLoja.bairrosSemEntrega.includes(bairroEntrega.value)) {
          const mensagemBairro = `Não há entrega para ${bairroEntrega.value}. Escolha retirada no local.`;
          marcarErroCampo(bairroEntrega, erroBairroEntrega, mensagemBairro);
          return { mensagem: mensagemBairro, campo: bairroEntrega };
        }
        if (!enderecoEntrega.value.trim()) {
          marcarErroCampo(enderecoEntrega, erroEnderecoEntrega, "Informe o endereço de entrega.");
          return { mensagem: "Informe o endereço de entrega.", campo: enderecoEntrega };
        }
      }

      return { mensagem: "", campo: null };
    }

    function montarMensagemPedido(numeroPedido) {
      const tipoAtendimento = atendimentoAtual();
      const tipoPedido = tipoEntrega.value;
      const { subtotal, taxa, total } = calcularTotaisPedido();

      const itens = carrinho
        .map((item) => {
          const extras = item.extras.length > 0 ? ` | Adicionais: ${item.extras.map((extra) => extra.nome).join(", ")}` : "";
          const obsItem = item.observacaoItem ? ` | Obs item: ${item.observacaoItem}` : "";
          return `${item.quantidade}x ${item.nome}${extras}${obsItem} - ${formatarMoeda(precoUnitarioItem(item) * item.quantidade)}`;
        })
        .join("\n");

      const linhas = [
        "NOVO PEDIDO - Tobia's Lanches",
        `Número do pedido: ${numeroPedido}`,
        "",
        `Cliente: ${nome.value.trim()}`,
        `Atendimento: ${tipoAtendimento === "no_local" ? "No Local" : "Delivery"}`,
        "Tempo aproximado: 20 a 40 minutos"
      ];

      if (tipoAtendimento === "no_local") {
        linhas.push(`Mesa: ${numeroMesa.value}`);
      } else if (tipoPedido === "retirada") {
        linhas.splice(4, 0, `Telefone: ${telefone.value.trim() || "Não informado"}`);
        linhas.push("Pedido para: Retirada no local");
        linhas.push(`Endereço de retirada: ${configuracaoLoja.enderecoRetirada}`);
      } else {
        linhas.splice(4, 0, `Telefone: ${telefone.value.trim() || "Não informado"}`);
        linhas.push("Pedido para: Entrega");
        linhas.push(`Localidade: ${bairroEntrega.value}`);
        linhas.push(`Endereço: ${enderecoEntrega.value.trim()}`);
        linhas.push(`Referência: ${referencia.value.trim() || "Não informada"}`);
        linhas.push(`Taxa de entrega: ${formatarMoeda(taxa)}`);
      }

      linhas.push(`Pagamento: ${pagamento.value}`);
      if (pagamento.value === "Pix") {
        linhas.push(`Chave PIX: ${configuracaoLoja.chavePix}`);
        linhas.push(`Titular PIX: ${configuracaoLoja.pixTitular}`);
        linhas.push(`Banco PIX: ${configuracaoLoja.pixBanco}`);
      }
      if (pagamento.value === "Dinheiro") {
        if (precisaTroco.checked) {
          linhas.push(`Troco para: ${formatarMoeda(Number(String(trocoPara.value).replace(",", ".")) || 0)}`);
        } else {
          linhas.push("Troco: Não precisa");
        }
      }
      linhas.push(`Observações gerais: ${observacoes.value.trim() || "Nenhuma"}`);
      linhas.push("-------------------------");
      linhas.push(itens);
      linhas.push("-------------------------");
      linhas.push(`Subtotal: ${formatarMoeda(subtotal)}`);
      linhas.push(`Total: ${formatarMoeda(total)}`);

      return linhas.join("\n");
    }

    function calcularCombosPossiveis() {
      if (!configuracaoCombos.ativo) {
        return 0;
      }
      const bebidas = produtos.filter((produto) =>
        produto.categoria === configuracaoCombos.categoriaBebida && produtoEstaDisponivel(produto));
      if (bebidas.length === 0) {
        return 0;
      }

      const totalBases = configuracaoCombos.categoriasBase.reduce((acumulador, categoriaBase) => {
        const quantidade = produtos.filter((produto) =>
          produto.categoria === categoriaBase && produtoEstaDisponivel(produto)).length;
        return acumulador + quantidade;
      }, 0);

      return totalBases * bebidas.length;
    }

    function atualizarResumoAdmin() {
      if (!adminTotalProdutos || !adminTotalDisponiveis || !adminTotalCombos) {
        return;
      }
      const totalProdutos = produtos.length;
      const totalDisponiveis = produtos.filter((produto) => produtoEstaDisponivel(produto)).length;
      adminTotalProdutos.textContent = String(totalProdutos);
      adminTotalDisponiveis.textContent = String(totalDisponiveis);
      adminTotalCombos.textContent = String(calcularCombosPossiveis());
    }

    function ativarAbaAdmin(idAba) {
      adminAbaAtual = idAba;
      adminTabs.forEach((botao) => {
        const ativo = botao.dataset.adminTab === idAba;
        botao.classList.toggle("ativo", ativo);
        botao.setAttribute("aria-selected", ativo ? "true" : "false");
      });

      adminPaineis.forEach((painel) => {
        const ativo = painel.dataset.adminPainel === idAba;
        painel.classList.toggle("ativo", ativo);
        painel.hidden = !ativo;
      });
    }

    function limparFormularioProdutoAdmin() {
      adminEdicaoAtiva = false;
      adminProdutoId.value = "";
      adminNomeProduto.value = "";
      adminDescricaoProduto.value = "";
      adminPrecoProduto.value = "";
      adminCategoriaProduto.value = categoriasProduto[0] || "";
      adminDisponivelProduto.checked = true;
      adminProdutoMsg.classList.add("oculto");
      adminProdutoMsg.textContent = "";
      renderizarChecklistAdicionaisAdmin();
      finalizarEdicaoAdmin();
    }

    function categoriaPermiteAdicionais(slug) {
      const infoCategoria = categoriasDetalhes.find((item) => item.slug === slug);
      if (infoCategoria) {
        return infoCategoria.permite_adicionais === true;
      }
      return slug === "pastel" || slug === "hamburguer";
    }

    function renderizarChecklistAdicionaisAdmin() {
      const adicionais = Object.values(adicionaisCatalogo);
      const categoria = adminCategoriaProduto.value;
      const permiteAdicional = categoriaPermiteAdicionais(categoria);
      adminAdicionaisChecklist.innerHTML = adicionais
        .map((adicional) => {
          const idSeguro = escaparHtml(adicional.id);
          const nomeSeguro = escaparHtml(adicional.nome);
          return `
            <label class="checkbox-linha add-on-item">
              <input type="checkbox" data-admin-adicional="${idSeguro}" ${!permiteAdicional ? "disabled" : ""} />
              ${nomeSeguro} (+${formatarMoeda(adicional.preco)})
            </label>
          `;
        })
        .join("");
    }

    function marcarAdicionaisAdmin(idsAdicionais = []) {
      adminAdicionaisChecklist.querySelectorAll("input[data-admin-adicional]").forEach((inputExtra) => {
        inputExtra.checked = idsAdicionais.includes(inputExtra.dataset.adminAdicional);
      });
    }

    function renderizarListaProdutosAdmin(opcoes = {}) {
      const resetarRolagem = Boolean(opcoes.resetarRolagem);
      const rolagemAnterior = adminListaProdutos.scrollTop;
      const termoBusca = (adminBuscaProduto?.value || "").trim().toLowerCase();
      const categoriaFiltro = adminFiltroCategoria?.value || "";
      const disponibilidadeFiltro = adminFiltroDisponibilidade?.value || "";

      const listaFiltrada = produtos
        .filter((produto) => {
          const nomeProduto = String(produto.nome || "").toLowerCase();
          const passaBusca = !termoBusca || nomeProduto.includes(termoBusca);
          const passaCategoria = !categoriaFiltro || produto.categoria === categoriaFiltro;
          const disponivel = produtoEstaDisponivel(produto);
          const passaDisponibilidade = disponibilidadeFiltro === "disponivel"
            ? disponivel
            : disponibilidadeFiltro === "indisponivel"
              ? !disponivel
              : true;
          return passaBusca && passaCategoria && passaDisponibilidade;
        })
        .slice()
        .sort((a, b) => a.id - b.id);

      if (adminResumoFiltro) {
        const partesFiltro = [];
        if (categoriaFiltro) {
          partesFiltro.push(`categoria: ${categoriasCatalogo[categoriaFiltro] || categoriaFiltro}`);
        }
        if (disponibilidadeFiltro) {
          partesFiltro.push(disponibilidadeFiltro === "disponivel" ? "status: disponíveis" : "status: indisponíveis");
        }
        if (termoBusca) {
          partesFiltro.push(`busca: "${adminBuscaProduto.value.trim()}"`);
        }
        const sufixoFiltro = partesFiltro.length > 0 ? ` (${partesFiltro.join(" | ")})` : "";
        adminResumoFiltro.textContent = `Mostrando ${listaFiltrada.length} de ${produtos.length} itens${sufixoFiltro}.`;
      }

      if (listaFiltrada.length === 0) {
        adminListaProdutos.innerHTML = `
          <li class="admin-item admin-item-vazio">
            <strong>Nenhum produto encontrado</strong>
            <p>Ajuste a busca ou os filtros para localizar um item cadastrado.</p>
          </li>
        `;
        adminListaProdutos.scrollTop = 0;
        return;
      }

      adminListaProdutos.innerHTML = listaFiltrada
        .map((produto) => {
          const disponivel = produtoEstaDisponivel(produto);
          const nomeProdutoSeguro = escaparHtml(produto.nome);
          const descricaoProdutoSegura = produto.descricao
            ? escaparHtml(produto.descricao)
            : "Sem descrição cadastrada.";
          const totalAdicionais = Array.isArray(produto.adicionais) ? produto.adicionais.length : 0;
          const exibirTagAdicionais = categoriaPermiteAdicionais(produto.categoria);
          const categoriaLabel = escaparHtml(categoriasCatalogo[produto.categoria] || produto.categoria);
          return `
            <li class="admin-item">
              <div class="admin-item-info">
                <div class="admin-item-topo">
                  <span class="admin-item-id">Produto #${produto.id}</span>
                  <span class="admin-tag admin-tag-status ${disponivel ? "admin-tag-ok" : "admin-tag-off"}">${disponivel ? "Disponível" : "Indisponível"}</span>
                </div>
                <strong>${nomeProdutoSeguro}</strong>
                <p class="admin-item-descricao">${descricaoProdutoSegura}</p>
                <div class="admin-item-metas">
                  <span class="admin-tag admin-tag-categoria">${categoriaLabel}</span>
                  <span class="admin-tag admin-tag-preco">${formatarMoeda(produto.preco)}</span>
                  ${exibirTagAdicionais ? `<span class="admin-tag admin-tag-extra">Adicionais: ${totalAdicionais}</span>` : ""}
                </div>
              </div>
              <div class="admin-item-acoes" role="group" aria-label="Ações do produto ${nomeProdutoSeguro}">
                <button type="button" class="botao botao-secundario admin-btn-edit" data-admin-acao="editar-produto" data-id="${produto.id}" aria-label="Editar produto ${nomeProdutoSeguro}">Editar</button>
                <button type="button" class="botao botao-secundario admin-btn-toggle" data-admin-acao="toggle-produto" data-id="${produto.id}" aria-label="${disponivel ? "Pausar" : "Ativar"} produto ${nomeProdutoSeguro}">${disponivel ? "Pausar" : "Ativar"}</button>
                <button type="button" class="botao botao-secundario admin-btn-remove" data-admin-acao="remover-produto" data-id="${produto.id}" aria-label="Excluir produto ${nomeProdutoSeguro}">Excluir</button>
              </div>
            </li>
          `;
        })
        .join("");
      adminListaProdutos.scrollTop = resetarRolagem ? 0 : rolagemAnterior;
    }

    function renderizarListaAdicionaisAdmin() {
      adminListaAdicionais.innerHTML = Object.values(adicionaisCatalogo)
        .map((adicional, indice) => {
          const idAdicionalSeguro = escaparHtml(adicional.id);
          const nomeAdicionalSeguro = escaparHtml(adicional.nome);
          const idDomSeguro = slugify(adicional.id) || `adicional_${Date.now()}_${indice}`;
          const inputNomeId = `adminAdicionalNome_${idDomSeguro}`;
          const inputPrecoId = `adminAdicionalPreco_${idDomSeguro}`;
          return `
            <div class="admin-adicional-item">
              <label class="sr-only" for="${inputNomeId}">Nome do adicional ${nomeAdicionalSeguro}</label>
              <input id="${inputNomeId}" type="text" value="${nomeAdicionalSeguro}" data-admin-adicional-nome="${idAdicionalSeguro}" maxlength="40" />
              <label class="sr-only" for="${inputPrecoId}">Preço do adicional ${nomeAdicionalSeguro}</label>
              <input id="${inputPrecoId}" type="number" value="${adicional.preco}" data-admin-adicional-preco="${idAdicionalSeguro}" min="0" step="0.01" />
              <button type="button" class="botao botao-secundario admin-btn-save" data-admin-acao="salvar-adicional" data-id="${idAdicionalSeguro}">Salvar</button>
              <button type="button" class="botao botao-secundario admin-btn-remove" data-admin-acao="remover-adicional" data-id="${idAdicionalSeguro}">Remover</button>
            </div>
          `;
        })
        .join("");
    }

    function preencherConfigCombosAdmin() {
      comboAtivo.checked = configuracaoCombos.ativo !== false;
      comboBasePastel.checked = configuracaoCombos.categoriasBase.includes("pastel");
      comboBaseHamburguer.checked = configuracaoCombos.categoriasBase.includes("hamburguer");
      comboDesconto.value = Number(configuracaoCombos.desconto || 0);
    }

    function aplicarAtualizacoesCardapio() {
      renderizarCategorias();
      mostrarProdutos();
      atualizarCarrinho();
      renderizarListaProdutosAdmin();
      renderizarListaAdicionaisAdmin();
      preencherConfigCombosAdmin();
      renderizarChecklistAdicionaisAdmin();
      atualizarResumoAdmin();
    }

    async function salvarProdutoAdmin() {
      if (!adminAutenticado) {
        mostrarErroAdmin("Faça login para salvar produtos.");
        return;
      }
      const nomeProduto = adminNomeProduto.value.trim();
      const descricaoProduto = adminDescricaoProduto.value.trim();
      const precoProduto = Number(String(adminPrecoProduto.value).replace(",", "."));
      const categoriaProduto = adminCategoriaProduto.value;
      const disponivelProduto = adminDisponivelProduto.checked;
      const idsAdicionais = categoriaPermiteAdicionais(categoriaProduto)
        ? Array.from(adminAdicionaisChecklist.querySelectorAll("input[data-admin-adicional]:checked"))
          .map((inputExtra) => inputExtra.dataset.adminAdicional)
          .filter((idExtra) => Boolean(adicionaisCatalogo[idExtra]))
        : [];

      if (!nomeProduto) {
        mostrarErroAdmin("Informe o nome do produto.");
        return;
      }
      if (!categoriaProduto) {
        mostrarErroAdmin("Selecione uma categoria válida.");
        return;
      }
      if (!Number.isFinite(precoProduto) || precoProduto < 0) {
        mostrarErroAdmin("Informe um preço válido.");
        return;
      }

      adminErro.classList.add("oculto");
      adminErro.textContent = "";
      const idEdicao = Number(adminProdutoId.value);
      const payload = {
        nome: nomeProduto,
        descricao: descricaoProduto,
        preco: precoProduto,
        categoria_slug: categoriaProduto,
        disponivel: disponivelProduto
      };

      let produtoSalvo = null;
      let erroOperacao = null;

      if (idEdicao) {
        const { data, error } = await supabase
          .from("produtos")
          .update(payload)
          .eq("id", idEdicao)
          .select()
          .single();
        if (error) {
          erroOperacao = error;
        } else {
          produtoSalvo = data;
        }
      } else {
        const { data, error } = await supabase
          .from("produtos")
          .insert([payload])
          .select()
          .single();
        if (error) {
          erroOperacao = error;
        } else {
          produtoSalvo = data;
        }
      }

      if (erroOperacao || !produtoSalvo) {
        mostrarErroAdmin("Não foi possível salvar o produto. Tente novamente.");
        console.error("Erro ao salvar produto", erroOperacao);
        return;
      }

      const produtoId = Number(produtoSalvo.id);
      const { error: erroRelacoes } = await supabase
        .from("produto_adicionais")
        .delete()
        .eq("produto_id", produtoId);

      if (erroRelacoes) {
        mostrarErroAdmin("Produto salvo, mas houve erro ao atualizar adicionais.");
        console.error("Erro ao limpar adicionais", erroRelacoes);
        return;
      }

      if (idsAdicionais.length > 0) {
        const relacoes = idsAdicionais.map((idAdicional) => ({
          produto_id: produtoId,
          adicional_id: idAdicional
        }));
        const { error: erroInsercaoRelacoes } = await supabase
          .from("produto_adicionais")
          .insert(relacoes);
        if (erroInsercaoRelacoes) {
          mostrarErroAdmin("Produto salvo, mas houve erro ao salvar adicionais.");
          console.error("Erro ao inserir adicionais", erroInsercaoRelacoes);
          return;
        }
      }

      const produtoAtualizado = {
        id: produtoId,
        nome: nomeProduto,
        descricao: descricaoProduto,
        preco: precoProduto,
        categoria: categoriaProduto,
        disponivel: disponivelProduto,
        adicionais: idsAdicionais
      };

      const indice = produtos.findIndex((produto) => produto.id === produtoAtualizado.id);
      if (indice >= 0) {
        produtos[indice] = produtoAtualizado;
      } else {
        produtos.push(produtoAtualizado);
      }

      limparFormularioProdutoAdmin();
      adminProdutoMsg.textContent = "Produto salvo com sucesso.";
      adminProdutoMsg.classList.remove("oculto");
      aplicarAtualizacoesCardapio();
      finalizarEdicaoAdmin();
    }

    function carregarProdutoParaEdicao(idProduto) {
      const produto = obterProdutoPorId(idProduto);
      if (!produto) {
        return;
      }

      adminProdutoId.value = String(produto.id);
      adminNomeProduto.value = produto.nome;
      adminDescricaoProduto.value = produto.descricao;
      adminPrecoProduto.value = String(produto.preco);
      adminCategoriaProduto.value = produto.categoria;
      adminDisponivelProduto.checked = produto.disponivel !== false;
      renderizarChecklistAdicionaisAdmin();
      marcarAdicionaisAdmin(produto.adicionais || []);
      adminProdutoMsg.textContent = `Editando produto #${produto.id}.`;
      adminProdutoMsg.classList.remove("oculto");
    }

    async function alternarDisponibilidadeProduto(idProduto) {
      if (!adminAutenticado) {
        mostrarErroAdmin("Faça login para alterar produtos.");
        return;
      }
      const produto = obterProdutoPorId(idProduto);
      if (!produto) {
        return;
      }
      const novoStatus = !produto.disponivel;
      const { error } = await supabase
        .from("produtos")
        .update({ disponivel: novoStatus })
        .eq("id", produto.id);
      if (error) {
        mostrarErroAdmin("Não foi possível atualizar a disponibilidade.");
        console.error("Erro ao atualizar disponibilidade", error);
        return;
      }
      produto.disponivel = novoStatus;
      aplicarAtualizacoesCardapio();
      finalizarEdicaoAdmin();
    }

    async function removerProdutoAdmin(idProduto) {
      if (!adminAutenticado) {
        mostrarErroAdmin("Faça login para remover produtos.");
        return;
      }
      const id = Number(idProduto);
      const produto = obterProdutoPorId(id);
      if (!produto) {
        return;
      }

      const confirmou = window.confirm(`Excluir o produto "${produto.nome}"?`);
      if (!confirmou) {
        return;
      }

      const { error } = await supabase
        .from("produtos")
        .delete()
        .eq("id", id);
      if (error) {
        mostrarErroAdmin("Não foi possível excluir o produto.");
        console.error("Erro ao excluir produto", error);
        return;
      }

      const indiceProduto = produtos.findIndex((registro) => registro.id === id);
      const carrinhoAntes = clonar(carrinho);
      produtos = produtos.filter((registro) => registro.id !== id);
      carrinho = carrinho.filter((item) => String(item.produtoId) !== String(id));
      salvarCarrinhoLocal();
      aplicarAtualizacoesCardapio();
      iniciarDesfazerAdmin({
        tipo: "produto",
        produto: clonar(produto),
        indice: indiceProduto,
        carrinhoAntes
      }, `Produto "${produto.nome}" excluído.`);
      finalizarEdicaoAdmin();
    }

    async function atualizarAdicionalAdmin(idAdicional) {
      if (!adminAutenticado) {
        mostrarErroAdmin("Faça login para atualizar adicionais.");
        return;
      }
      const campoNome = adminListaAdicionais.querySelector(`input[data-admin-adicional-nome="${idAdicional}"]`);
      const campoPreco = adminListaAdicionais.querySelector(`input[data-admin-adicional-preco="${idAdicional}"]`);
      if (!campoNome || !campoPreco) {
        return;
      }

      const nomeAdicional = campoNome.value.trim();
      const precoAdicional = Number(String(campoPreco.value).replace(",", "."));

      if (!nomeAdicional || !Number.isFinite(precoAdicional) || precoAdicional < 0) {
        mostrarErroAdmin("Preencha nome e preço válidos para o adicional.");
        return;
      }

      const { error } = await supabase
        .from("adicionais")
        .update({ nome: nomeAdicional, preco: precoAdicional })
        .eq("id", idAdicional);
      if (error) {
        mostrarErroAdmin("Não foi possível atualizar o adicional.");
        console.error("Erro ao atualizar adicional", error);
        return;
      }

      adicionaisCatalogo[idAdicional] = {
        id: idAdicional,
        nome: nomeAdicional,
        preco: precoAdicional
      };
      adminErro.textContent = "";
      adminErro.classList.add("oculto");
      aplicarAtualizacoesCardapio();
      finalizarEdicaoAdmin();
    }

    async function removerAdicionalAdmin(idAdicional) {
      if (!adminAutenticado) {
        mostrarErroAdmin("Faça login para remover adicionais.");
        return;
      }
      const adicional = adicionaisCatalogo[idAdicional];
      if (!adicional) {
        return;
      }

      const confirmou = window.confirm(`Excluir o adicional "${adicional.nome}"?`);
      if (!confirmou) {
        return;
      }

      const produtosAfetados = produtos
        .filter((produto) => (produto.adicionais || []).includes(idAdicional))
        .map((produto) => ({
          id: produto.id,
          adicionais: clonar(produto.adicionais || [])
        }));

      const { error } = await supabase
        .from("adicionais")
        .delete()
        .eq("id", idAdicional);
      if (error) {
        mostrarErroAdmin("Não foi possível excluir o adicional.");
        console.error("Erro ao excluir adicional", error);
        return;
      }

      delete adicionaisCatalogo[idAdicional];
      produtos = produtos.map((produto) => ({
        ...produto,
        adicionais: (produto.adicionais || []).filter((idExtra) => idExtra !== idAdicional)
      }));
      aplicarAtualizacoesCardapio();
      iniciarDesfazerAdmin({
        tipo: "adicional",
        adicional: clonar(adicional),
        produtosAfetados
      }, `Adicional "${adicional.nome}" excluído.`);
      finalizarEdicaoAdmin();
    }

    async function adicionarAdicionalAdmin() {
      if (!adminAutenticado) {
        mostrarErroAdmin("Faça login para adicionar adicionais.");
        return;
      }
      const nome = adminNovoAdicionalNome.value.trim();
      const preco = Number(String(adminNovoAdicionalPreco.value).replace(",", "."));
      if (!nome || !Number.isFinite(preco) || preco < 0) {
        mostrarErroAdmin("Informe nome e preço válidos para adicionar.");
        return;
      }

      let id = slugify(nome);
      if (!id) {
        id = `extra_${Date.now()}`;
      }
      let sufixo = 1;
      while (adicionaisCatalogo[id]) {
        id = `${slugify(nome)}_${sufixo}`;
        sufixo += 1;
      }

      const { error } = await supabase
        .from("adicionais")
        .insert([{ id, nome, preco }]);
      if (error) {
        mostrarErroAdmin("Não foi possível adicionar o adicional.");
        console.error("Erro ao adicionar adicional", error);
        return;
      }

      adicionaisCatalogo[id] = { id, nome, preco };
      adminErro.textContent = "";
      adminErro.classList.add("oculto");
      adminNovoAdicionalNome.value = "";
      adminNovoAdicionalPreco.value = "";
      aplicarAtualizacoesCardapio();
      finalizarEdicaoAdmin();
    }

    async function salvarConfigCombosAdmin() {
      if (!adminAutenticado) {
        mostrarErroAdmin("Faça login para salvar combos.");
        return;
      }
      const categoriasBase = [];
      if (comboBasePastel.checked) {
        categoriasBase.push("pastel");
      }
      if (comboBaseHamburguer.checked) {
        categoriasBase.push("hamburguer");
      }
      if (categoriasBase.length === 0) {
        categoriasBase.push("pastel");
      }

      const novoConfig = {
        ativo: comboAtivo.checked,
        desconto: Math.max(0, Number(String(comboDesconto.value).replace(",", ".")) || 0),
        categorias_base: categoriasBase,
        categoria_bebida_slug: configuracaoCombos.categoriaBebida || "refrigerante"
      };

      const { error } = await supabase
        .from("combos_config")
        .update(novoConfig)
        .eq("id", 1);
      if (error) {
        mostrarErroAdmin("Não foi possível salvar a configuração de combos.");
        console.error("Erro ao salvar combos", error);
        return;
      }

      configuracaoCombos = {
        ...configuracaoCombos,
        ativo: novoConfig.ativo,
        desconto: novoConfig.desconto,
        categoriasBase
      };
      aplicarAtualizacoesCardapio();
      finalizarEdicaoAdmin();
    }

    function atualizarVisibilidadeFeedbackAdmin() {
      if (!adminFeedback) {
        return;
      }
      const mensagemVisivel = !adminAcaoMsg.classList.contains("oculto") && adminAcaoMsg.textContent.trim() !== "";
      const botaoVisivel = !botaoDesfazerAdmin.classList.contains("oculto");
      adminFeedback.classList.toggle("oculto", !(mensagemVisivel || botaoVisivel));
    }

    function limparDesfazerAdmin() {
      ultimaExclusaoAdmin = null;
      if (timerDesfazerAdmin) {
        clearTimeout(timerDesfazerAdmin);
        timerDesfazerAdmin = null;
      }
      adminAcaoMsg.textContent = "";
      adminAcaoMsg.classList.add("oculto");
      botaoDesfazerAdmin.classList.add("oculto");
      atualizarVisibilidadeFeedbackAdmin();
    }

    function iniciarDesfazerAdmin(operacao, texto) {
      limparDesfazerAdmin();
      ultimaExclusaoAdmin = operacao;
      adminAcaoMsg.textContent = `${texto} Você pode desfazer por 8 segundos.`;
      adminAcaoMsg.classList.remove("oculto");
      botaoDesfazerAdmin.classList.remove("oculto");
      atualizarVisibilidadeFeedbackAdmin();
      timerDesfazerAdmin = setTimeout(() => {
        limparDesfazerAdmin();
      }, JANELA_DESFAZER_MS);
    }

    async function desfazerUltimaExclusaoAdmin() {
      if (!ultimaExclusaoAdmin) {
        return;
      }
      if (!adminAutenticado) {
        mostrarErroAdmin("Faça login para desfazer.");
        return;
      }
      const operacao = ultimaExclusaoAdmin;
      limparDesfazerAdmin();

      if (operacao.tipo === "produto" && operacao.produto) {
        const produto = operacao.produto;
        const payload = {
          id: produto.id,
          nome: produto.nome,
          descricao: produto.descricao || "",
          preco: produto.preco,
          categoria_slug: produto.categoria,
          disponivel: produto.disponivel !== false
        };
        const { error } = await supabase
          .from("produtos")
          .insert([payload]);
        if (error) {
          mostrarErroAdmin("Não foi possível desfazer a exclusão do produto.");
          console.error("Erro ao desfazer produto", error);
          return;
        }

        if (Array.isArray(produto.adicionais) && produto.adicionais.length > 0) {
          const relacoes = produto.adicionais.map((idAdicional) => ({
            produto_id: produto.id,
            adicional_id: idAdicional
          }));
          const { error: erroRelacoes } = await supabase
            .from("produto_adicionais")
            .insert(relacoes);
          if (erroRelacoes) {
            mostrarErroAdmin("Produto restaurado, mas houve erro ao recuperar adicionais.");
            console.error("Erro ao restaurar adicionais", erroRelacoes);
          }
        }

        const jaExiste = produtos.some((produto) => produto.id === operacao.produto.id);
        if (!jaExiste) {
          const indice = Math.max(0, Math.min(Number(operacao.indice) || 0, produtos.length));
          produtos.splice(indice, 0, operacao.produto);
        }
        if (Array.isArray(operacao.carrinhoAntes)) {
          carrinho = operacao.carrinhoAntes;
          salvarCarrinhoLocal();
        }
        aplicarAtualizacoesCardapio();
        adminProdutoMsg.textContent = `Exclusão desfeita: ${operacao.produto.nome}.`;
        adminProdutoMsg.classList.remove("oculto");
        finalizarEdicaoAdmin();
        return;
      }

      if (operacao.tipo === "adicional" && operacao.adicional) {
        const adicional = operacao.adicional;
        const { error } = await supabase
          .from("adicionais")
          .insert([{ id: adicional.id, nome: adicional.nome, preco: adicional.preco }]);
        if (error) {
          mostrarErroAdmin("Não foi possível desfazer a exclusão do adicional.");
          console.error("Erro ao desfazer adicional", error);
          return;
        }

        const relacoes = Array.isArray(operacao.produtosAfetados)
          ? operacao.produtosAfetados
            .filter((registro) => Array.isArray(registro.adicionais) && registro.adicionais.includes(adicional.id))
            .map((registro) => ({ produto_id: registro.id, adicional_id: adicional.id }))
          : [];
        if (relacoes.length > 0) {
          const { error: erroRelacoes } = await supabase
            .from("produto_adicionais")
            .insert(relacoes);
          if (erroRelacoes) {
            mostrarErroAdmin("Adicional restaurado, mas houve erro ao recuperar vínculos.");
            console.error("Erro ao restaurar vínculos", erroRelacoes);
          }
        }

        adicionaisCatalogo[adicional.id] = adicional;
        if (Array.isArray(operacao.produtosAfetados)) {
          operacao.produtosAfetados.forEach((registro) => {
            const produto = obterProdutoPorId(registro.id);
            if (produto) {
              produto.adicionais = Array.isArray(registro.adicionais) ? registro.adicionais : [];
            }
          });
        }
        aplicarAtualizacoesCardapio();
        adminProdutoMsg.textContent = `Exclusão desfeita: adicional ${operacao.adicional.nome}.`;
        adminProdutoMsg.classList.remove("oculto");
        finalizarEdicaoAdmin();
      }
    }

    function mostrarErroAdmin(texto) {
      adminErro.textContent = texto;
      adminErro.classList.remove("oculto");
    }

    function abrirAdmin() {
      if (adminEmail) {
        adminEmail.value = "";
      }
      if (adminSenha) {
        adminSenha.value = "";
      }
      botaoAbrirAdmin.setAttribute("aria-expanded", "true");
      const focoInicial = adminAutenticado
        ? document.querySelector(".admin-tab.ativo") || botaoFecharAdmin
        : adminEmail;
      abrirModal(painelAdmin, focoInicial);
    }

    function fecharAdmin() {
      botaoAbrirAdmin.setAttribute("aria-expanded", "false");
      fecharModal(painelAdmin, botaoAbrirAdmin);
      adminErro.textContent = "";
      adminErro.classList.add("oculto");
      limparDesfazerAdmin();
      finalizarEdicaoAdmin();
    }

    function aplicarEstadoAdmin() {
      adminLoginBloco.classList.toggle("oculto", adminAutenticado);
      adminConteudo.classList.toggle("oculto", !adminAutenticado);
      adminAcoesFooter.classList.toggle("oculto", !adminAutenticado);
      if (adminAutenticado) {
        adminErro.textContent = "";
        adminErro.classList.add("oculto");
      }
      if (adminAutenticado) {
        renderizarChecklistAdicionaisAdmin();
        renderizarListaProdutosAdmin({ resetarRolagem: true });
        renderizarListaAdicionaisAdmin();
        preencherConfigCombosAdmin();
        atualizarResumoAdmin();
        ativarAbaAdmin(adminAbaAtual);
        if (!adminEdicaoAtiva && !adminTemFocoEmEdicao()) {
          finalizarEdicaoAdmin();
        }
      }
    }

    async function entrarAdmin() {
      const email = adminEmail?.value.trim();
      const senha = adminSenha?.value.trim();

      if (!email || !senha) {
        mostrarErroAdmin("Informe e-mail e senha para entrar.");
        return;
      }

      const { error } = await supabase.auth.signInWithPassword({ email, password: senha });
      if (error) {
        mostrarErroAdmin("Credenciais inválidas. Verifique e tente novamente.");
        console.error("Erro ao autenticar", error);
        return;
      }

      adminAutenticado = true;
      if (adminSenha) {
        adminSenha.value = "";
      }
      adminErro.classList.add("oculto");
      aplicarEstadoAdmin();
    }

    async function sairAdmin() {
      await supabase.auth.signOut();
      adminAutenticado = false;
      aplicarEstadoAdmin();
      limparFormularioProdutoAdmin();
      limparDesfazerAdmin();
      finalizarEdicaoAdmin();
    }

    function atualizarBotoesBloqueio() {
      const restante = Math.max(0, Math.ceil((bloqueioEnvioAte - Date.now()) / 1000));
      const bloqueado = restante > 0;
      const carrinhoVazio = carrinho.length === 0;
      botaoFinalizar.disabled = bloqueado || carrinhoVazio;
      botaoFinalizar.setAttribute("aria-disabled", botaoFinalizar.disabled ? "true" : "false");
      botaoConfirmarEnvio.disabled = bloqueado;
      botaoFinalizar.textContent = bloqueado ? `Aguarde ${restante}s` : "Finalizar Pedido";
      botaoConfirmarEnvio.textContent = bloqueado ? `Aguarde ${restante}s` : "Confirmar e Enviar";
    }

    function iniciarBloqueioEnvio(segundos = 8) {
      bloqueioEnvioAte = Date.now() + (segundos * 1000);
      atualizarBotoesBloqueio();

      if (timerBloqueio) {
        clearInterval(timerBloqueio);
      }

      timerBloqueio = setInterval(() => {
        atualizarBotoesBloqueio();
        if (Date.now() >= bloqueioEnvioAte) {
          clearInterval(timerBloqueio);
          timerBloqueio = null;
        }
      }, 500);
    }

    document.addEventListener("click", (evento) => {
      const alvo = evento.target;

      if (alvo.classList.contains("categoria")) {
        document.querySelectorAll(".categoria").forEach((categoria) => {
          const ativa = categoria === alvo;
          categoria.classList.toggle("ativa", ativa);
          categoria.setAttribute("aria-pressed", ativa ? "true" : "false");
        });
        categoriaAtual = alvo.dataset.categoria;
        mostrarProdutos();
      }

      const botaoAdicionarCombo = alvo.closest(".botao-adicionar-combo");
      if (botaoAdicionarCombo) {
        const card = botaoAdicionarCombo.closest(".combo-card");
        const baseId = card.querySelector(".combo-base").value;
        const bebidaId = card.querySelector(".combo-bebida").value;
        const categoriaBase = botaoAdicionarCombo.dataset.baseCategoria;

        const itemBase = obterProdutoPorId(baseId);
        const bebida = obterProdutoPorId(bebidaId);
        if (!itemBase || !bebida) {
          return;
        }

        const nomeCombo = `Combo ${categoriasCatalogo[categoriaBase] || categoriaBase}: ${itemBase.nome} + ${bebida.nome}`;
        const produtoCombo = {
          id: `combo-${categoriaBase}-${itemBase.id}-${bebida.id}`,
          nome: nomeCombo,
          preco: calcularPrecoCombo(itemBase, bebida)
        };

        adicionarAoCarrinho(produtoCombo, [], "");
        card.querySelector(".combo-base").value = "";
        card.querySelector(".combo-bebida").value = "";
        atualizarPrecoCardCombo(card);
        aplicarFeedbackBotaoAdicionar(botaoAdicionarCombo);
      }

      const botaoAdicionar = alvo.closest(".botao-adicionar");
      if (botaoAdicionar) {
        const idProduto = Number(botaoAdicionar.dataset.id);
        const produto = produtos.find((registro) => registro.id === idProduto);

        if (!produto || !produtoEstaDisponivel(produto)) {
          return;
        }

        const card = botaoAdicionar.closest(".produto-card");
        const extras = obterExtrasDoCard(card);
        const obsItemInput = card.querySelector(".obs-item");
        const obsItem = obsItemInput ? obsItemInput.value.trim() : "";

        adicionarAoCarrinho(produto, extras, obsItem);
        aplicarFeedbackBotaoAdicionar(botaoAdicionar);

        card.querySelectorAll("input[data-extra]").forEach((inputExtra) => {
          inputExtra.checked = false;
        });
        if (obsItemInput) {
          obsItemInput.value = "";
        }
      }
    });

    areaProdutos.addEventListener("change", (evento) => {
      const seletorCombo = evento.target.closest(".combo-select");
      if (!seletorCombo) {
        return;
      }
      const card = seletorCombo.closest(".combo-card");
      if (card) {
        atualizarPrecoCardCombo(card);
      }
    });

    listaCarrinho.addEventListener("click", (evento) => {
      const botao = evento.target.closest("button[data-acao]");
      if (!botao) {
        return;
      }

      const acao = botao.dataset.acao;
      const chave = botao.dataset.chave;

      if (acao === "mais") {
        alterarQuantidade(chave, 1);
      }
      if (acao === "menos") {
        alterarQuantidade(chave, -1);
      }
      if (acao === "remover") {
        removerItem(chave);
      }
    });

    radiosAtendimento.forEach((radio) => {
      radio.addEventListener("change", atualizarFluxoAtendimento);
    });

    tipoEntrega.addEventListener("change", atualizarVisibilidadeEntrega);

    bairroEntrega.addEventListener("change", () => {
      atualizarTaxaInfo();
      atualizarResumoValores();
      salvarFormularioLocal();
    });

    pagamento.addEventListener("change", atualizarBlocosPagamento);

    precisaTroco.addEventListener("change", () => {
      trocoParaBox.classList.toggle("oculto", !precisaTroco.checked);
      trocoPara.required = precisaTroco.checked;
      if (!precisaTroco.checked) {
        trocoPara.value = "";
      }
      salvarFormularioLocal();
    });

    botaoCopiarPix.addEventListener("click", copiarChavePix);

    telefone.addEventListener("input", () => {
      telefone.value = aplicarMascaraTelefone(telefone.value);
      salvarFormularioLocal();
    });

    formCliente.addEventListener("input", (evento) => {
      limparErroCampo(evento.target);
      if (evento.target !== telefone) {
        salvarFormularioLocal();
      }
    });

    formCliente.addEventListener("change", (evento) => {
      limparErroCampo(evento.target);
      salvarFormularioLocal();
    });

    botaoCarrinho.addEventListener("click", abrirCarrinho);
    botaoAbrirCarrinhoMobile.addEventListener("click", abrirCarrinho);
    botaoFechar.addEventListener("click", fecharCarrinho);
    botaoAbrirAdmin.addEventListener("click", abrirAdmin);
    botaoFecharAdmin.addEventListener("click", fecharAdmin);
    botaoEntrarAdmin.addEventListener("click", entrarAdmin);
    botaoSairAdmin.addEventListener("click", sairAdmin);
    botaoSalvarProduto.addEventListener("click", salvarProdutoAdmin);
    botaoLimparProduto.addEventListener("click", limparFormularioProdutoAdmin);
    botaoAdicionarAdicional.addEventListener("click", adicionarAdicionalAdmin);
    botaoSalvarCombos.addEventListener("click", salvarConfigCombosAdmin);
    adminTabs.forEach((botao) => {
      botao.addEventListener("click", () => {
        ativarAbaAdmin(botao.dataset.adminTab);
      });
    });

    function marcarEdicaoAdmin(evento) {
      if (!adminAutenticado) {
        return;
      }
      const alvo = evento.target;
      if (!alvo || !painelAdmin.contains(alvo)) {
        return;
      }
      if (alvo === adminBuscaProduto || alvo === adminFiltroCategoria || alvo === adminFiltroDisponibilidade) {
        return;
      }
      adminEdicaoAtiva = true;
    }

    if (adminConteudo) {
      adminConteudo.addEventListener("input", marcarEdicaoAdmin);
      adminConteudo.addEventListener("change", marcarEdicaoAdmin);
    }

    if (adminLoginForm) {
      adminLoginForm.addEventListener("submit", (evento) => {
        evento.preventDefault();
        entrarAdmin();
      });
    }

    adminCategoriaProduto.addEventListener("change", () => {
      renderizarChecklistAdicionaisAdmin();
      const produtoEmEdicao = adminProdutoId.value ? obterProdutoPorId(Number(adminProdutoId.value)) : null;
      marcarAdicionaisAdmin(produtoEmEdicao ? (produtoEmEdicao.adicionais || []) : []);
    });

    if (adminBuscaProduto) {
      adminBuscaProduto.addEventListener("input", () => {
        renderizarListaProdutosAdmin({ resetarRolagem: true });
      });
    }

    if (adminFiltroCategoria) {
      adminFiltroCategoria.addEventListener("change", () => {
        renderizarListaProdutosAdmin({ resetarRolagem: true });
      });
    }

    if (adminFiltroDisponibilidade) {
      adminFiltroDisponibilidade.addEventListener("change", () => {
        renderizarListaProdutosAdmin({ resetarRolagem: true });
      });
    }

    botaoDesfazerAdmin.addEventListener("click", desfazerUltimaExclusaoAdmin);

    adminListaProdutos.addEventListener("click", (evento) => {
      const botao = evento.target.closest("button[data-admin-acao]");
      if (!botao) {
        return;
      }
      const acao = botao.dataset.adminAcao;
      const idProduto = Number(botao.dataset.id);

      if (acao === "editar-produto") {
        carregarProdutoParaEdicao(idProduto);
      }
      if (acao === "toggle-produto") {
        alternarDisponibilidadeProduto(idProduto);
      }
      if (acao === "remover-produto") {
        removerProdutoAdmin(idProduto);
      }
    });

    adminListaAdicionais.addEventListener("click", (evento) => {
      const botao = evento.target.closest("button[data-admin-acao]");
      if (!botao) {
        return;
      }
      const acao = botao.dataset.adminAcao;
      const idAdicional = botao.dataset.id;

      if (acao === "salvar-adicional") {
        atualizarAdicionalAdmin(idAdicional);
      }
      if (acao === "remover-adicional") {
        removerAdicionalAdmin(idAdicional);
      }
    });

    caixaCarrinho.addEventListener("click", (evento) => {
      if (evento.target === caixaCarrinho) {
        fecharCarrinho();
      }
    });
    const monitorarTeclado = () => {
      setTimeout(atualizarEstadoTecladoCarrinho, 60);
    };

    caixaCarrinho.addEventListener("focusin", monitorarTeclado);
    caixaCarrinho.addEventListener("focusout", monitorarTeclado);
    window.addEventListener("resize", atualizarEstadoTecladoCarrinho);
    if (window.visualViewport) {
      window.visualViewport.addEventListener("resize", atualizarEstadoTecladoCarrinho);
      window.visualViewport.addEventListener("scroll", atualizarEstadoTecladoCarrinho);
    }
    if (typeof mediaTecladoMobile.addEventListener === "function") {
      mediaTecladoMobile.addEventListener("change", atualizarEstadoTecladoCarrinho);
    } else if (typeof mediaTecladoMobile.addListener === "function") {
      mediaTecladoMobile.addListener(atualizarEstadoTecladoCarrinho);
    }

    function iniciarFluxoFinalizacao() {
      limparErro();

      if (Date.now() < bloqueioEnvioAte) {
        mostrarErro("Aguarde alguns segundos antes de enviar outro pedido.", true);
        return false;
      }

      const validacao = validarFormulario();
      if (validacao.mensagem) {
        mostrarErro(validacao.mensagem, !validacao.campo);
        if (validacao.campo && typeof validacao.campo.focus === "function") {
          validacao.campo.focus();
        }
        return false;
      }

      const numeroPedido = gerarNumeroPedido();
      const mensagem = montarMensagemPedido(numeroPedido);
      pedidoPendente = {
        numeroPedido,
        mensagem
      };
      abrirConfirmacao(mensagem);
      return true;
    }

    botaoFinalizar.addEventListener("click", () => {
      iniciarFluxoFinalizacao();
    });

    formCliente.addEventListener("submit", (evento) => {
      evento.preventDefault();
      iniciarFluxoFinalizacao();
    });

    botaoCancelarConfirmacao.addEventListener("click", () => {
      fecharConfirmacao();
    });
    botaoFecharConfirmacaoTopo.addEventListener("click", fecharConfirmacao);

    botaoConfirmarEnvio.addEventListener("click", () => {
      if (!pedidoPendente) {
        return;
      }

      if (Date.now() < bloqueioEnvioAte) {
        mostrarErro("Aguarde alguns segundos antes de enviar outro pedido.", true);
        return;
      }

      const url = `https://wa.me/${configuracaoLoja.numeroWhatsApp}?text=${encodeURIComponent(pedidoPendente.mensagem)}`;
      const janelaWhatsApp = window.open(url, "_blank", "noopener,noreferrer");
      if (!janelaWhatsApp) {
        mostrarErro("Não foi possível abrir o WhatsApp. Permita pop-ups e tente novamente.", true);
        return;
      }

      iniciarBloqueioEnvio(8);
      fecharConfirmacao();
      abrirCarrinho();
      pedidoPendente = null;
    });

    modalConfirmacao.addEventListener("click", (evento) => {
      if (evento.target === modalConfirmacao) {
        fecharConfirmacao();
      }
    });

    painelAdmin.addEventListener("click", (evento) => {
      if (evento.target === painelAdmin) {
        // Evita fechamento acidental durante interação com o login.
        return;
      }
    });

    document.addEventListener("keydown", (evento) => {
      limitarFocoNoModal(evento);

      if (evento.key === "Escape") {
        if (painelAdmin.classList.contains("show")) {
          fecharAdmin();
          return;
        }
        if (modalConfirmacao.classList.contains("show")) {
          fecharConfirmacao();
          return;
        }
        if (caixaCarrinho.classList.contains("show")) {
          fecharCarrinho();
        }
      }
    });


    async function inicializarAplicacao() {
      await carregarDadosSupabase();
      const { data } = await supabase.auth.getSession();
      adminAutenticado = Boolean(data?.session);
      aplicarEstadoAdmin();
      limparFormularioProdutoAdmin();

      restaurarCarrinhoLocal();
      restaurarFormularioLocal();
      atualizarBairrosEntregaUI();
      renderizarCategorias();
      mostrarProdutos();
      atualizarFluxoAtendimento();
      atualizarBlocosPagamento();
      atualizarCarrinho();
      atualizarStatusLoja();
      atualizarBotoesBloqueio();

      iniciarRealtime();
    }

    supabase.auth.onAuthStateChange((_evento, sessao) => {
      adminAutenticado = Boolean(sessao);
      aplicarEstadoAdmin();
    });

    inicializarAplicacao();

    setInterval(atualizarStatusLoja, 60000);
    window.addEventListener("focus", atualizarStatusLoja);
    })();
  </script>
</body>

</html>
